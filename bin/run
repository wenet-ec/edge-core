    echo -e "${BLUE}Edge Services Commands${NC}"
    echo "Manages: Edge Agent, Local Registry, Watchtower"
    echo ""
    echo "Usage: ./bin/run edge <command> [options]"
    echo ""
    echo -e "${YELLOW}Container Management:${NC}"
    echo "  up [options]           - Start edge services"
    echo "  down [options]         - Stop and remove edge services"
    echo "  start                  - Build and start edge services"
    echo "  stop [services]        - Stop edge services"
    echo "  restart [services]     - Restart edge services"
    echo "  build [services]       - Build edge service images"
    echo "  logs [service]         - View edge service logs"
    echo "  ps                     - List running edge services"
    echo ""
    echo -e "${YELLOW}Edge Agent Commands:${NC}"
    echo "  agent <mix-cmd>        - Run Mix command in Edge Agent"
    echo "  agent:shell            - Open Edge Agent IEx shell"
    echo "  agent:format           - Format Edge Agent code"
    echo "  agent:lint             - Lint Edge Agent code"
    echo "  agent:test [opts]      - Run Edge Agent tests"
    echo "  agent:quality          - Run quality checks"
    echo "  agent:security         - Run security checks"
    echo "  agent:check            - Run all checks (format, deps, security, lint, dialyzer, test)"
    echo ""
    echo -e "${YELLOW}Database Commands:${NC}"
    echo "  db:migrate [opts]      - Run database migrations"
    echo "  db:setup               - Setup database"
    echo "  db:reset               - Reset database (destructive)"
    echo ""
    echo -e "${YELLOW}Utilities:${NC}"
    echo "  exec <svc> <cmd>       - Execute command in service"
    echo "  shell <service>        - Open bash shell in service"
    echo "  clean                  - Clean up volumes and containers"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ./bin/run edge up -d"
    echo "  ./bin/run edge agent:test"
    echo "  ./bin/run edge logs edge_agent"
    echo "  ENV=production ./bin/run edge start"
}

# Show help for all commands
show_all_help() {
    echo -e "${BLUE}All Services Commands${NC}"
    echo "Manages: All cloud and edge services together"
    echo ""
    echo "Usage: ./bin/run all <command> [options]"
    echo ""
    echo -e "${YELLOW}Container Management:${NC}"
    echo "  up [options]           - Start all services"
    echo "  down [options]         - Stop and remove all services"
    echo "  start                  - Build and start all services"
    echo "  stop [services]        - Stop services"
    echo "  restart [services]     - Restart services"
    echo "  build [services]       - Build service images"
    echo "  logs [service]         - View service logs"
    echo "  ps                     - List all running services"
    echo ""
    echo -e "${YELLOW}Combined Quality Commands:${NC}"
    echo "  format                 - Format all code (admin + agent)"
    echo "  lint                   - Lint all code (admin + agent)"
    echo "  test                   - Run all tests (admin + agent)"
    echo "  quality                - Run quality checks on all services"
    echo "  security               - Run security checks on all services"
    echo ""
    echo -e "${YELLOW}Database Commands:${NC}"
    echo "  db:setup               - Setup all databases"
    echo "  db:reset               - Reset all databases (destructive)"
    echo ""
    echo -e "${YELLOW}Utilities:${NC}"
    echo "  clean                  - Clean up all volumes and containers"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ./bin/run all up -d"
    echo "  ./bin/run all format"
    echo "  ./bin/run all test"
    echo "  ENV=production ./bin/run all start"
}

# Show main help
show_help() {
    echo -e "${BLUE}Edge Core Management Script${NC}"
    echo "===================================="
    echo ""
    echo "Usage: ./bin/run <scope> <command> [options]"
    echo ""
    echo -e "${YELLOW}Scopes:${NC}"
    echo "  cloud     - Manage cloud infrastructure (admin, VPN, DB, metrics)"
    echo "  edge      - Manage edge services (agent, registry, watchtower)"
    echo "  all       - Manage all services together"
    echo "  k8s       - Manage k8s test cluster (kind + helmfile)"
    echo ""
    echo -e "${YELLOW}Global Options:${NC}"
    echo "  ENV=production    - Use production environment (default: local)"
    echo "  VARIANT=test      - Use variant compose files (e.g., cloud.test.yml)"
    echo ""
    echo -e "${YELLOW}Common Commands:${NC}"
    echo "  check             - Check Docker installation and environment"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ./bin/run check"
    echo "  ./bin/run cloud up -d"
    echo "  ./bin/run edge agent:test"
    echo "  ./bin/run all format"
    echo "  ENV=production ./bin/run cloud start"
    echo "  ENV=production VARIANT=test ./bin/run cloud up -d"
    echo ""
    echo "For scope-specific help, run:"
    echo "  ./bin/run cloud"
    echo "  ./bin/run edge"
    echo "  ./bin/run all"
    echo "  ./bin/run k8s"
}

# Handle cloud infrastructure commands
handle_cloud() {
    local compose_file="-f $CLOUD_COMPOSE_FILE"
    local command=$1
    shift || true

    case "$command" in
        "")
            show_cloud_help
            ;;
        up|down|start|stop|restart|build|ps)
            check_docker
            case "$command" in
                start)
                    log "Building and starting cloud services..."
                    docker compose $compose_file up --build "$@"
                    ;;
                *)
                    log "Running: docker compose $compose_file $command $@"
                    docker compose $compose_file "$command" "$@"
                    ;;
            esac
            ;;
        logs)
            check_docker
            if [ $# -eq 0 ]; then
                docker compose $compose_file logs -f
            else
                docker compose $compose_file logs -f "$@"
            fi
            ;;
        admin)
            check_docker
            if [ $# -eq 0 ]; then
                warn "No admin command specified"
                exit 1
            fi
            log "Running Edge Admin command: mix $*"
            docker compose $compose_file run --rm edge_admin_a1 mix "$@"
            ;;
        admin:shell)
            check_docker
            log "Opening Edge Admin IEx shell..."
            docker compose $compose_file run --rm edge_admin_a1 iex -S mix
            ;;
        admin:format)
            check_docker
            log "Formatting Edge Admin code..."
            docker compose $compose_file run --rm edge_admin_a1 mix format
            log "Formatting Nexmaker code..."
            docker compose $compose_file run --rm --workdir /nexmaker edge_admin_a1 mix format
            ;;
        admin:lint)
            check_docker
            log "Linting Edge Admin code..."
            docker compose $compose_file run --rm edge_admin_a1 mix lint
            ;;
        admin:test)
            check_docker
            log "Running Edge Admin tests..."
            docker compose $compose_file run --rm edge_admin_test "$@"
            ;;
        admin:quality)
            check_docker
            log "Running Edge Admin quality checks..."
            docker compose $compose_file run --rm edge_admin_a1 mix quality
            ;;
        admin:security)
            check_docker
            log "Running Edge Admin security checks..."
            docker compose $compose_file run --rm edge_admin_a1 mix security
            ;;
        admin:check)
            check_docker
            log "Running Edge Admin checks..."
            docker compose $compose_file run --rm edge_admin_a1 mix check
            ;;
        db:migrate)
            check_docker
            log "Running Edge Admin database migrations..."
            docker compose $compose_file run --rm edge_admin_a1 mix ecto.migrate "$@"
            ;;
        db:setup)
            check_docker
            log "Setting up Edge Admin database..."
            docker compose $compose_file run --rm edge_admin_a1 mix ecto.setup
            ;;
        db:reset)
            check_docker
            warn "This will delete all Edge Admin data! Press Ctrl+C to cancel, Enter to continue..."
            read -r
            log "Resetting Edge Admin database..."
            docker compose $compose_file run --rm edge_admin_a1 mix ecto.reset
            ;;
        exec)
            check_docker
            if [ $# -lt 2 ]; then
                warn "Usage: ./bin/run cloud exec <service> <command>"
                exit 1
            fi
            service=$1
            shift
            log "Executing in $service: $*"
            docker compose $compose_file exec "$service" "$@"
            ;;
        shell)
            check_docker
            if [ $# -eq 0 ]; then
                warn "Usage: ./bin/run cloud shell <service>"
                echo "Available services: edge_admin_a1, edge_admin_a2, edge_admin_b1, edge_vpn, edge_vpn_db, etc."
                exit 1
            fi
            service=$1
            log "Opening shell in $service..."
            docker compose $compose_file exec "$service" /bin/bash
            ;;
        clean)
            check_docker
            log "Cleaning up cloud infrastructure..."
            docker compose $compose_file down --volumes --remove-orphans
            ;;
        *)
            error "Unknown cloud command: $command"
            show_cloud_help
            ;;
    esac
}

# Handle edge services commands
handle_edge() {
    local compose_file="-f $EDGE_COMPOSE_FILE"
    local command=$1
    shift || true

    case "$command" in
        "")
            show_edge_help
            ;;
        up|down|start|stop|restart|build|ps)
            check_docker
            case "$command" in
                start)
                    log "Building and starting edge services..."
                    docker compose $compose_file up --build "$@"
                    ;;
                *)
                    log "Running: docker compose $compose_file $command $@"
                    docker compose $compose_file "$command" "$@"
                    ;;
            esac
            ;;
        logs)
            check_docker
            if [ $# -eq 0 ]; then
                docker compose $compose_file logs -f
