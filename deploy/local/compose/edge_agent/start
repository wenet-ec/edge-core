#!/bin/bash
# deploy/local/compose/edge_agent/start

set -o errexit
set -o pipefail
set -o nounset

# Cleanup function to be called on container shutdown
cleanup() {
    echo "Received shutdown signal, cleaning up..."

    # Signal only the netclient daemon WE started. Do NOT use pgrep/pkill
    # by name — this container runs with `pid: host`, so a name match would
    # find every netclient daemon on the host (including ones owned by admin
    # containers running on the same machine) and tear them down with us.
    # On clean exit netclient restores /etc/resolv.conf from its backup itself.
    if [ -n "${NETCLIENT_PID:-}" ] && kill -0 "$NETCLIENT_PID" 2>/dev/null; then
        echo "Stopping netclient daemon (PID: $NETCLIENT_PID)..."
        kill -TERM "$NETCLIENT_PID" 2>/dev/null || true

        # Wait for it to exit gracefully (max 5 seconds)
        for _ in {1..5}; do
            if ! kill -0 "$NETCLIENT_PID" 2>/dev/null; then
                echo "Netclient daemon stopped gracefully"
                break
            fi
            sleep 1
        done

        # Force kill if still running
        if kill -0 "$NETCLIENT_PID" 2>/dev/null; then
            echo "Force killing netclient daemon (PID: $NETCLIENT_PID)"
            kill -9 "$NETCLIENT_PID" 2>/dev/null || true
        fi
    else
        echo "No netclient daemon to stop"
    fi

    # Clean up routing policy rules (netmaker creates these with priorities 3000, 2500, 2000)
    echo "Cleaning up routing policy rules..."
    ip rule delete pref 3000 2>/dev/null || true
    ip rule delete pref 2500 2>/dev/null || true
    ip rule delete pref 2000 2>/dev/null || true

    # Remove WireGuard interface from host
    if ip link show netmaker &>/dev/null; then
        echo "Removing netmaker WireGuard interface..."
        ip link delete netmaker 2>/dev/null || true
    fi

    echo "Cleanup complete"
}

# Trap EXIT, INT, and TERM signals
trap cleanup EXIT INT TERM

# Use UPYUN ("Yun") mirror for hex.pm — if the Fastly-backed default is flaky
# https://hex.pm/docs/mirrors
# export HEX_MIRROR="https://hexpm.upyun.com"
mix deps.get
mix compile
mix ecto.migrate

# Only unload the kernel WireGuard module when running in userspace mode.
# In userspace mode (wireguard-go), if the kernel wireguard module is loaded
# (e.g. contaminated by a prior agent run on the same host), netlink.LinkAdd
# returns EINVAL after the TUN device is created, which destroys the UAPI
# socket and breaks DERP. rmmod clears this before netclient daemon starts.
# In kernel mode, netclient's Create() self-heals by doing LinkDel+LinkAdd
# on the existing interface — rmmod must NOT run or it breaks that path.
if [ "${WG_QUICK_USERSPACE_IMPLEMENTATION:-}" = "wireguard-go" ]; then
    echo "Userspace WireGuard mode: unloading kernel wireguard module (if present)..."
    rmmod wireguard 2>/dev/null || true
fi

# Clean up any stale WireGuard interface from previous run
echo "Cleaning up stale WireGuard interface..."
ip link delete netmaker 2>/dev/null || true

# netclient daemon requires /etc/netmaker-resolv.backup.conf to exist on init.
# It creates this backup itself the first time it writes resolv.conf, and deletes
# it on clean shutdown when it restores resolv.conf. If the backup is missing
# (either first boot or after a clean shutdown) we pre-seed it so the daemon
# can start cleanly.
#
# If resolv.conf already has the netmaker header (leftover from a prior run),
# we strip the netmaker lines when seeding the backup — otherwise the backup
# would contain the netmaker header itself, which defeats its purpose.
RESOLV_TARGET=$(readlink -f /etc/resolv.conf 2>/dev/null || echo /etc/resolv.conf)
BACKUP=/etc/netmaker-resolv.backup.conf
if [ ! -f "$BACKUP" ]; then
    echo "Seeding resolv.conf backup for netclient..."
    grep -v "generated by netmaker\|DO NOT EDIT\|^$" "$RESOLV_TARGET" > "$BACKUP" 2>/dev/null || printf 'nameserver 1.1.1.1\n' > "$BACKUP"
fi

# Tell netclient where to fetch the DERP map overlay.
# The agent serves this endpoint — netclient inherits this env at fork time and
# fetches it on every DERP connect attempt (always fresh from settings store).
# Must be set before netclient daemon starts; cannot be pushed into a running process.
export DERP_MAP_URLS="http://localhost:${API_PORT:-44000}/api/v1/derp_map"

# Start netclient daemon in the background
echo "Starting netclient daemon..."
netclient daemon &
NETCLIENT_PID=$!
echo "Netclient daemon started with PID: $NETCLIENT_PID"

# Give netclient a head start to initialize
echo "Waiting for netclient to initialize..."
sleep 5

# Start the development server with hot reloading
echo "Starting Phoenix server..."
export PHX_SERVER=true
mix phx.server &
PHOENIX_PID=$!

# Wait for Phoenix server to exit
wait $PHOENIX_PID
