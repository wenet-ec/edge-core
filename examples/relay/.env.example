# examples/relay/.env.example
#
# Copy this file to .env and fill in your values before running.
#
#   cp .env.example .env
#
# Deploy this on the relay machine — separate from your admin core.
# The relay machine needs ports 80, 443, and 3478/udp open to the internet.
# Do NOT put a reverse proxy or Cloudflare orange-cloud in front of port 443.
# Cloudflare DNS-only (grey cloud) is fine.

# ==============================================================================
# EDGE RELAY (derper)
# ==============================================================================

# REQUIRED — public hostname for this relay node. DNS must point here.
# Let's Encrypt will obtain a TLS cert for this hostname automatically.
DERP_HOSTNAME=edge-relay-1.yourdomain.com

# REQUIRED — contact email for Let's Encrypt account
DERP_ACME_EMAIL=you@yourdomain.com

# Certificate mode: letsencrypt (default), manual
DERP_CERT_MODE=letsencrypt

# ==============================================================================
# EDGE RELAY MAP (Caddy — serves the map JSON at /derpmap/default)
# ==============================================================================

# REQUIRED — public hostname for the relay map server. DNS must point here.
# Caddy will obtain a TLS cert for this hostname automatically.
DERP_MAP_HOSTNAME=edge-relay-map-1.yourdomain.com
