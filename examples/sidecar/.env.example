# examples/sidecar/.env.example
#
# Minimal env for running the agent as a sidecar container.
# Copy to .env and fill in the values marked REQUIRED.

# REQUIRED — URL to fetch a public enrollment key from your admin
# Replace with your actual admin IP/hostname and cluster name
PUBLIC_ENROLLMENT_KEY_URL=http://your-admin-ip-or-domain:34000/api/v1/clusters/default/enrollment_keys/public

# Use a random identity instead of deriving it from the host machine's persistent ID.
# Required in sidecar mode — the host identity is not meaningful here and
# multiple sidecars on the same node would collide without this.
USE_RANDOM_ID=true

# WireGuard userspace mode — required when running inside a container
WG_QUICK_USERSPACE_IMPLEMENTATION=wireguard-go
