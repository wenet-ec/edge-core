#!/bin/bash
# deploy/production/compose/edge_agent/edge_bashrc

# Edge Agent Custom Bash Configuration
# This rcfile provides a full bash experience with hostscript integration

# Get node ID from environment (set by shell.ex)
NODE_ID="${EDGE_NODE_ID:-unknown}"
# Take first 8 characters of node ID for compact display
SHORT_NODE_ID="${NODE_ID:0:8}"

# Get current username (will be the SSH username like 'admin')
CURRENT_USER="${USER:-root}"

# Set a custom prompt: username@node-<short-id>:/path#
# Format: admin@node-a1b2c3d4:/app#
export PS1="\[\033[1;32m\]${CURRENT_USER}\[\033[0m\]@\[\033[1;36m\]node-${SHORT_NODE_ID}\[\033[0m\]:\[\033[1;34m\]\w\[\033[0m\]# "

# Enable history
HISTFILE=~/.bash_history
HISTSIZE=1000
HISTFILESIZE=2000
HISTCONTROL=ignoreboth

# Append to history file, don't overwrite
shopt -s histappend

# Check window size after each command
shopt -s checkwinsize

# Enable programmable completion
if [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
fi

# Enable color support for ls and grep
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# Useful aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# List of bash builtins that should NOT be routed to the host
# These must run in the current shell context
BASH_BUILTINS="cd exit logout source . alias unalias export set unset declare local readonly typeset eval exec history jobs bg fg wait disown suspend trap"

# Check if a command is a bash builtin
_is_builtin() {
    case " $BASH_BUILTINS " in
        *" $1 "*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# Override command_not_found_handle - called when command doesn't exist in container
command_not_found_handle() {
    # Route to host for execution
    hostscript "$@"
    return $?
}

# Create a general command wrapper using the DEBUG trap
# This intercepts EVERY command before execution
_debug_trap() {
    local cmd="${BASH_COMMAND}"

    # Extract the command name (first word)
    local cmd_name="${cmd%% *}"

    # Skip if it's a builtin, function, or internal bash operation
    if _is_builtin "$cmd_name"; then
        return 0
    fi

    # Skip bash internal operations
    if [[ "$cmd" =~ ^(PROMPT_COMMAND|_debug_trap|command_not_found_handle) ]]; then
        return 0
    fi

    # Execute the command on the host and prevent local execution
    # Note: We can't actually prevent execution from DEBUG trap,
    # so we rely on command_not_found_handle for missing commands
    # and explicit aliases for commands that exist in both places
    return 0
}

# We can't reliably intercept ALL commands without breaking bash
# So we use a hybrid approach:
# 1. command_not_found_handle for commands not in container
# 2. Explicit functions for common commands that exist in both places

# List of common commands to always route to host
# This is a pragmatic approach - cover the most common cases
for cmd in docker docker-compose podman crictl ctr nerdctl buildah systemctl journalctl service \
           ip ss netstat iptables nft route ifconfig ping traceroute dig nslookup \
           ps top htop pgrep pkill kill killall pidof \
           free vmstat iostat mpstat sar dmesg \
           df du lsblk fdisk parted mkfs mount umount blkid wipefs \
           lsmod modprobe rmmod insmod lspci lsusb lscpu \
           uname hostnamectl hostname \
           systemd-analyze timedatectl localectl networkctl nmcli \
           firewall-cmd ufw fail2ban-client \
           apt apt-get dpkg yum dnf rpm zypper pacman \
           snap flatpak \
           wg wg-quick \
           useradd userdel usermod groupadd groupdel passwd chpasswd \
           kubectl k3s microk8s; do
    eval "function $cmd() { hostscript $cmd \"\$@\"; }"
done
