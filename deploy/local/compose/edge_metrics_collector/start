#!/bin/sh
# deploy/local/compose/edge_metrics_collector/start

set -o errexit
set -o pipefail
set -o nounset

echo "Starting up Edge Metrics Collector..."

echo "Starting VPN management service on :8430..."
edge_metrics_collector_wrapper &
GO_PID=$!

# Start vmagent as the main process
echo "Starting vmagent..."
echo "  Config Path: ${VMAGENT_CONFIG_PATH:-/etc/prometheus/prometheus.yml}"
echo "  Remote Write URL: ${VMAGENT_REMOTE_WRITE_URL:-http://edge_metrics_storage:8428/api/v1/write}"

# Setup signal handlers for graceful shutdown
cleanup() {
    echo "Shutting down services..."
    kill $GO_PID 2>/dev/null || true
    # kill $TAILSCALE_PID 2>/dev/null || true
    exit 0
}

trap cleanup SIGTERM SIGINT

# Start vmagent as the main foreground process
exec vmagent \
    -promscrape.config="${VMAGENT_CONFIG_PATH:-/etc/prometheus/prometheus.yml}" \
    -promscrape.config.strictParse="${VMAGENT_STRICT_PARSE:-false}" \
    -remoteWrite.url="${VMAGENT_REMOTE_WRITE_URL:-http://edge_metrics_storage:8428/api/v1/write}" \
    -httpListenAddr=":8429"