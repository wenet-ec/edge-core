# .dockerignore
# IMPORTANT: This uses allowlist approach - exclude everything, then include what's needed
# This prevents massive build contexts

# Exclude everything by default
*

# Include only what's needed for edge_admin builds
!deploy/
!edge_admin/mix.exs
!edge_admin/mix.lock
!edge_admin/config/
!edge_admin/lib/
!edge_admin/priv/repo/
!edge_admin/priv/static/robots.txt
!edge_admin/rel/

# Include nexmaker dependency
!nexmaker/

# For edge_agent builds (only include if needed)
!edge_agent/mix.exs
!edge_agent/mix.lock
!edge_agent/config/
!edge_agent/lib/
!edge_agent/priv/repo/
!edge_agent/priv/static/robots.txt
!edge_agent/rel/

# Exclude build artifacts even if parent is included
**/_build/
**/deps/
**/node_modules/
**/*.log
**/.git/
**/tmp/
**/cover/
**/erl_crash.dump
**/.DS_Store