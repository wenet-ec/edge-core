#!/bin/bash
# deploy/local/compose/edge_admin/entrypoint

set -o errexit
set -o pipefail
set -o nounset

# Set default PostgreSQL user if not provided
if [ -z "${POSTGRES_USER:-}" ]; then
    base_postgres_image_default_user='postgres'
    export POSTGRES_USER="${base_postgres_image_default_user}"
fi

# Function to wait for a service to be available
wait_for_service() {
    local host=$1
    local port=$2
    local service_name=$3
    
    echo "Waiting for ${service_name} to be available..."
    while ! nc -z "${host}" "${port}"; do
        >&2 echo "${service_name} is unavailable - sleeping"
        sleep 1
    done
    >&2 echo "${service_name} is available"
}

# Function to ensure required VPN users exist
ensure_vpn_users() {
    echo "Ensuring required VPN users exist..."
    
    # Wait for VPN wrapper to be available first
    wait_for_service "edge_vpn" "8081" "VPN Wrapper"
    
    # Array of users to create
    declare -a users=("edge-admins" "edge-nodes")
    
    for user_name in "${users[@]}"; do
        echo "Checking for ${user_name} user..."
        USER_RESPONSE=$(curl -s "${VPN_WRAPPER_URL}/api/v1/user?name=${user_name}")
        
        if echo "${USER_RESPONSE}" | grep -q "${user_name}"; then
            echo "User ${user_name} already exists"
        else
            echo "Creating ${user_name} user..."
            CREATE_RESPONSE=$(curl -s -X POST "${VPN_WRAPPER_URL}/api/v1/user" \
                -H "Content-Type: application/json" \
                -d '{"name": "'"${user_name}"'"}')
            
            if echo "${CREATE_RESPONSE}" | grep -q '"id":"'; then
                echo "Successfully created ${user_name} user"
            else
                echo "ERROR: Failed to create ${user_name} user"
                echo "Response: ${CREATE_RESPONSE}"
                exit 1
            fi
        fi
    done
    
    echo "All required VPN users are available"
}

# Function to setup VPN connection (modified)
setup_vpn_connection() {
    echo "Setting up VPN connection..."
    
    # Start tailscaled daemon
    echo "Starting tailscaled daemon..."
    mkdir -p /var/run/tailscale /var/cache/tailscale /var/lib/tailscale
    tailscaled --state=/var/lib/tailscale/tailscaled.state --socket=/var/run/tailscale/tailscaled.sock &
    sleep 2
    
    # Check if we're already authenticated and connected
    echo "Checking existing Tailscale status..."
    if tailscale status 2>/dev/null | grep -q "edge-admin" && tailscale status 2>/dev/null | grep -q "100\."; then
        echo "Already authenticated and connected, using existing state"
        return 0
    fi
    
    # Check if we have existing state and try to bring it up
    if [ -f "/var/lib/tailscale/tailscaled.state" ] && [ -s "/var/lib/tailscale/tailscaled.state" ]; then
        echo "Found existing Tailscale state, checking if it's valid..."
        
        sleep 2  # Give tailscaled time to read the state
        
        if tailscale status 2>/dev/null | grep -q "Logged out"; then
            echo "Existing state is logged out, need new authentication..."
        elif tailscale status 2>/dev/null | grep -q "edge-admin"; then
            echo "Found valid existing authentication, attempting to connect..."
            if tailscale up --login-server="${VPN_URL}" --accept-dns=false --hostname=edge-admin; then
                sleep 2
                if tailscale status 2>/dev/null | grep -q "100\."; then
                    echo "Successfully reconnected using existing credentials"
                    return 0
                fi
            fi
            echo "Failed to reconnect with existing state, will get new auth..."
        else
            echo "Existing state is not usable, will get new authentication..."
        fi
    fi
    
    echo "Getting new VPN authentication for edge-admin..."
    
    # Get edge-admins user ID
    USER_RESPONSE=$(curl -s "${VPN_WRAPPER_URL}/api/v1/user?name=edge-admins")
    USER_ID=$(echo "${USER_RESPONSE}" | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)
    
    if [ -z "${USER_ID}" ]; then
        echo "ERROR: Could not find edge-admins user ID"
        exit 1
    fi
    
    echo "Using edge-admins user ID: ${USER_ID}"
    
    # Get preauth key for edge-admin
    echo "Getting preauth key for edge-admin..."
    EXPIRATION=$(date -d "+1 hour" --iso-8601=seconds)

    PREAUTH_RESPONSE=$(curl -s -X POST "${VPN_WRAPPER_URL}/api/v1/preauthkey" \
        -H "Content-Type: application/json" \
        -d '{
            "user": "'"${USER_ID}"'", 
            "reusable": false, 
            "ephemeral": false,
            "expiration": "'"${EXPIRATION}"'"
        }')
    
    PREAUTH_KEY=$(echo "${PREAUTH_RESPONSE}" | grep -o '"key":"[^"]*"' | cut -d'"' -f4)
    
    if [ -z "${PREAUTH_KEY}" ]; then
        echo "ERROR: Failed to get preauth key for edge-admin"
        echo "Response: ${PREAUTH_RESPONSE}"
        exit 1
    fi

    echo "Preauth key obtained for edge-admin: ${PREAUTH_KEY}"
    
    # Connect to VPN with new preauth key
    tailscale up --login-server="${VPN_URL}" --authkey="${PREAUTH_KEY}" --accept-dns=false --hostname=edge-admin
}

# Main execution flow (modified)
echo "Starting Edge Admin setup..."

# Wait for PostgreSQL
wait_for_service "${POSTGRES_HOST}" "${POSTGRES_PORT}" "PostgreSQL"

# Ensure both edge-admins and edge-nodes users exist
ensure_vpn_users

# Setup VPN connection for this edge-admin instance
setup_vpn_connection

if [ $? -eq 0 ]; then
    echo "Successfully connected to VPN"
    tailscale status
else
    echo "ERROR: Failed to connect to VPN"
    exit 1
fi

echo "All prerequisites ready, starting application..."
exec "$@"