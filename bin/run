#!/bin/bash
# bin/run - Edge Core Management Script
#
# Usage:
#   ./bin/run cloud <command>     # Manage cloud infrastructure (admin, VPN, metrics)
#   ./bin/run edge <command>      # Manage edge services (agent)
#   ./bin/run all <command>       # Manage all services together

# Exit on any error
set -e

# Make script executable from anywhere
cd "$(dirname "$0")/.."

# Use ENV from environment or default to local
ENV=${ENV:-local}
CLOUD_COMPOSE_FILE="deploy/${ENV}/cloud.yml"
EDGE_COMPOSE_FILE="deploy/${ENV}/edge.yml"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Helper functions
log() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }
section() { echo -e "${CYAN}=== $1 ===${NC}"; }

# Check if Docker is installed and running
check_docker() {
    if ! command -v docker &> /dev/null; then
        error "Docker is not installed"
    fi

    if ! docker info > /dev/null 2>&1; then
        error "Docker is not running"
    fi
}

# Validate environment
validate_env() {
    if [ "$ENV" != "local" ] && [ "$ENV" != "production" ]; then
        error "Invalid environment. Must be 'local' or 'production'"
    fi
}

# Validate compose file exists
validate_compose_file() {
    local file=$1
    if [ ! -f "$file" ]; then
        error "Compose file not found: $file"
    fi
}

# Show help for cloud commands
show_cloud_help() {
    echo -e "${BLUE}Cloud Infrastructure Commands${NC}"
    echo "Manages: Edge Admin, VPN (Netmaker), Database, Metrics, Message Broker"
    echo ""
    echo "Usage: ./bin/run cloud <command> [options]"
    echo ""
    echo -e "${YELLOW}Container Management:${NC}"
    echo "  up [options]           - Start cloud services"
    echo "  down [options]         - Stop and remove cloud services"
    echo "  start                  - Build and start cloud services"
    echo "  stop [services]        - Stop cloud services"
    echo "  restart [services]     - Restart cloud services"
    echo "  build [services]       - Build cloud service images"
    echo "  logs [service]         - View cloud service logs"
    echo "  ps                     - List running cloud services"
    echo ""
    echo -e "${YELLOW}Edge Admin Commands:${NC}"
    echo "  admin <mix-cmd>        - Run Mix command in Edge Admin"
    echo "  admin:shell            - Open Edge Admin IEx shell"
    echo "  admin:format           - Format Edge Admin code"
    echo "  admin:lint             - Lint Edge Admin code"
    echo "  admin:test [opts]      - Run Edge Admin tests"
    echo "  admin:quality          - Run quality checks"
    echo "  admin:security         - Run security checks"
    echo ""
    echo -e "${YELLOW}Database Commands:${NC}"
    echo "  db:migrate [opts]      - Run database migrations"
    echo "  db:setup               - Setup database"
    echo "  db:reset               - Reset database (destructive)"
    echo ""
    echo -e "${YELLOW}Utilities:${NC}"
    echo "  exec <svc> <cmd>       - Execute command in service"
    echo "  shell <service>        - Open bash shell in service"
    echo "  clean                  - Clean up volumes and containers"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ./bin/run cloud up -d"
    echo "  ./bin/run cloud admin:test"
    echo "  ./bin/run cloud logs edge_admin"
    echo "  ENV=production ./bin/run cloud start"
}

# Show help for edge commands
show_edge_help() {
    echo -e "${BLUE}Edge Services Commands${NC}"
    echo "Manages: Edge Agent, Local Registry, Watchtower"
    echo ""
    echo "Usage: ./bin/run edge <command> [options]"
    echo ""
    echo -e "${YELLOW}Container Management:${NC}"
    echo "  up [options]           - Start edge services"
    echo "  down [options]         - Stop and remove edge services"
    echo "  start                  - Build and start edge services"
    echo "  stop [services]        - Stop edge services"
    echo "  restart [services]     - Restart edge services"
    echo "  build [services]       - Build edge service images"
    echo "  logs [service]         - View edge service logs"
    echo "  ps                     - List running edge services"
    echo ""
    echo -e "${YELLOW}Edge Agent Commands:${NC}"
    echo "  agent <mix-cmd>        - Run Mix command in Edge Agent"
    echo "  agent:shell            - Open Edge Agent IEx shell"
    echo "  agent:format           - Format Edge Agent code"
    echo "  agent:lint             - Lint Edge Agent code"
    echo "  agent:test [opts]      - Run Edge Agent tests"
    echo "  agent:quality          - Run quality checks"
    echo "  agent:security         - Run security checks"
    echo ""
    echo -e "${YELLOW}Database Commands:${NC}"
    echo "  db:migrate [opts]      - Run database migrations"
    echo "  db:setup               - Setup database"
    echo "  db:reset               - Reset database (destructive)"
    echo ""
    echo -e "${YELLOW}Utilities:${NC}"
    echo "  exec <svc> <cmd>       - Execute command in service"
    echo "  shell <service>        - Open bash shell in service"
    echo "  clean                  - Clean up volumes and containers"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ./bin/run edge up -d"
    echo "  ./bin/run edge agent:test"
    echo "  ./bin/run edge logs edge_agent"
    echo "  ENV=production ./bin/run edge start"
}

# Show help for all commands
show_all_help() {
    echo -e "${BLUE}All Services Commands${NC}"
    echo "Manages: All cloud and edge services together"
    echo ""
    echo "Usage: ./bin/run all <command> [options]"
    echo ""
    echo -e "${YELLOW}Container Management:${NC}"
    echo "  up [options]           - Start all services"
    echo "  down [options]         - Stop and remove all services"
    echo "  start                  - Build and start all services"
    echo "  stop [services]        - Stop services"
    echo "  restart [services]     - Restart services"
    echo "  build [services]       - Build service images"
    echo "  logs [service]         - View service logs"
    echo "  ps                     - List all running services"
    echo ""
    echo -e "${YELLOW}Combined Quality Commands:${NC}"
    echo "  format                 - Format all code (admin + agent)"
    echo "  lint                   - Lint all code (admin + agent)"
    echo "  test                   - Run all tests (admin + agent)"
    echo "  quality                - Run quality checks on all services"
    echo "  security               - Run security checks on all services"
    echo ""
    echo -e "${YELLOW}Database Commands:${NC}"
    echo "  db:setup               - Setup all databases"
    echo "  db:reset               - Reset all databases (destructive)"
    echo ""
    echo -e "${YELLOW}Utilities:${NC}"
    echo "  clean                  - Clean up all volumes and containers"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ./bin/run all up -d"
    echo "  ./bin/run all format"
    echo "  ./bin/run all test"
    echo "  ENV=production ./bin/run all start"
}

# Show main help
show_help() {
    echo -e "${BLUE}Edge Core Management Script${NC}"
    echo "===================================="
    echo ""
    echo "Usage: ./bin/run <scope> <command> [options]"
    echo ""
    echo -e "${YELLOW}Scopes:${NC}"
    echo "  cloud     - Manage cloud infrastructure (admin, VPN, DB, metrics)"
    echo "  edge      - Manage edge services (agent, registry, watchtower)"
    echo "  all       - Manage all services together"
    echo ""
    echo -e "${YELLOW}Global Options:${NC}"
    echo "  ENV=production    - Use production environment (default: local)"
    echo ""
    echo -e "${YELLOW}Common Commands:${NC}"
    echo "  check             - Check Docker installation and environment"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ./bin/run check"
    echo "  ./bin/run cloud up -d"
    echo "  ./bin/run edge agent:test"
    echo "  ./bin/run all format"
    echo "  ENV=production ./bin/run cloud start"
    echo ""
    echo "For scope-specific help, run:"
    echo "  ./bin/run cloud"
    echo "  ./bin/run edge"
    echo "  ./bin/run all"
}

# Handle cloud infrastructure commands
handle_cloud() {
    local compose_file="-f $CLOUD_COMPOSE_FILE"
    local command=$1
    shift || true

    case "$command" in
        "")
            show_cloud_help
            ;;
        up|down|start|stop|restart|build|ps)
            check_docker
            case "$command" in
                start)
                    log "Building and starting cloud services..."
                    docker compose $compose_file up --build "$@"
                    ;;
                *)
                    log "Running: docker compose $compose_file $command $@"
                    docker compose $compose_file "$command" "$@"
                    ;;
            esac
            ;;
        logs)
            check_docker
            if [ $# -eq 0 ]; then
                docker compose $compose_file logs -f
            else
                docker compose $compose_file logs -f "$@"
            fi
            ;;
        admin)
            check_docker
            if [ $# -eq 0 ]; then
                warn "No admin command specified"
                exit 1
            fi
            log "Running Edge Admin command: mix $*"
            docker compose $compose_file run --rm edge_admin mix "$@"
            ;;
        admin:shell)
            check_docker
            log "Opening Edge Admin IEx shell..."
            docker compose $compose_file run --rm edge_admin iex -S mix
            ;;
        admin:format)
            check_docker
            log "Formatting Edge Admin code..."
            docker compose $compose_file run --rm edge_admin mix format
            ;;
        admin:lint)
            check_docker
            log "Linting Edge Admin code..."
            docker compose $compose_file run --rm edge_admin mix lint
            ;;
        admin:test)
            check_docker
            log "Running Edge Admin tests..."
            docker compose $compose_file run --rm edge_admin_test "$@"
            ;;
        admin:quality)
            check_docker
            log "Running Edge Admin quality checks..."
            docker compose $compose_file run --rm edge_admin mix quality
            ;;
        admin:security)
            check_docker
            log "Running Edge Admin security checks..."
            docker compose $compose_file run --rm edge_admin mix security
            ;;
        db:migrate)
            check_docker
            log "Running Edge Admin database migrations..."
            docker compose $compose_file run --rm edge_admin mix ecto.migrate "$@"
            ;;
        db:setup)
            check_docker
            log "Setting up Edge Admin database..."
            docker compose $compose_file run --rm edge_admin mix ecto.setup
            ;;
        db:reset)
            check_docker
            warn "This will delete all Edge Admin data! Press Ctrl+C to cancel, Enter to continue..."
            read -r
            log "Resetting Edge Admin database..."
            docker compose $compose_file run --rm edge_admin mix ecto.reset
            ;;
        exec)
            check_docker
            if [ $# -lt 2 ]; then
                warn "Usage: ./bin/run cloud exec <service> <command>"
                exit 1
            fi
            service=$1
            shift
            log "Executing in $service: $*"
            docker compose $compose_file exec "$service" "$@"
            ;;
        shell)
            check_docker
            if [ $# -eq 0 ]; then
                warn "Usage: ./bin/run cloud shell <service>"
                echo "Available services: edge_admin, edge_vpn, edge_vpn_db, etc."
                exit 1
            fi
            service=$1
            log "Opening shell in $service..."
            docker compose $compose_file exec "$service" /bin/bash
            ;;
        clean)
            check_docker
            log "Cleaning up cloud infrastructure..."
            docker compose $compose_file down --volumes --remove-orphans
            ;;
        *)
            error "Unknown cloud command: $command"
            show_cloud_help
            ;;
    esac
}

# Handle edge services commands
handle_edge() {
    local compose_file="-f $EDGE_COMPOSE_FILE"
    local command=$1
    shift || true

    case "$command" in
        "")
            show_edge_help
            ;;
        up|down|start|stop|restart|build|ps)
            check_docker
            case "$command" in
                start)
                    log "Building and starting edge services..."
                    docker compose $compose_file up --build "$@"
                    ;;
                *)
                    log "Running: docker compose $compose_file $command $@"
                    docker compose $compose_file "$command" "$@"
                    ;;
            esac
            ;;
        logs)
            check_docker
            if [ $# -eq 0 ]; then
                docker compose $compose_file logs -f
            else
                docker compose $compose_file logs -f "$@"
            fi
            ;;
        agent)
            check_docker
            if [ $# -eq 0 ]; then
                warn "No agent command specified"
                exit 1
            fi
            log "Running Edge Agent command: mix $*"
            docker compose $compose_file run --rm edge_agent mix "$@"
            ;;
        agent:shell)
            check_docker
            log "Opening Edge Agent IEx shell..."
            docker compose $compose_file run --rm edge_agent iex -S mix
            ;;
        agent:format)
            check_docker
            log "Formatting Edge Agent code..."
            docker compose $compose_file run --rm edge_agent mix format
            ;;
        agent:lint)
            check_docker
            log "Linting Edge Agent code..."
            docker compose $compose_file run --rm edge_agent mix lint
            ;;
        agent:test)
            check_docker
            log "Running Edge Agent tests..."
            docker compose $compose_file run --rm edge_agent_test "$@"
            ;;
        agent:quality)
            check_docker
            log "Running Edge Agent quality checks..."
            docker compose $compose_file run --rm edge_agent mix quality
            ;;
        agent:security)
            check_docker
            log "Running Edge Agent security checks..."
            docker compose $compose_file run --rm edge_agent mix security
            ;;
        db:migrate)
            check_docker
            log "Running Edge Agent database migrations..."
            docker compose $compose_file run --rm edge_agent mix ecto.migrate "$@"
            ;;
        db:setup)
            check_docker
            log "Setting up Edge Agent database..."
            docker compose $compose_file run --rm edge_agent mix ecto.setup
            ;;
        db:reset)
            check_docker
            warn "This will delete all Edge Agent data! Press Ctrl+C to cancel, Enter to continue..."
            read -r
            log "Resetting Edge Agent database..."
            docker compose $compose_file run --rm edge_agent mix ecto.reset
            ;;
        exec)
            check_docker
            if [ $# -lt 2 ]; then
                warn "Usage: ./bin/run edge exec <service> <command>"
                exit 1
            fi
            service=$1
            shift
            log "Executing in $service: $*"
            docker compose $compose_file exec "$service" "$@"
            ;;
        shell)
            check_docker
            if [ $# -eq 0 ]; then
                warn "Usage: ./bin/run edge shell <service>"
                echo "Available services: edge_agent, local_registry, watchtower"
                exit 1
            fi
            service=$1
            log "Opening shell in $service..."
            docker compose $compose_file exec "$service" /bin/bash
            ;;
        clean)
            check_docker
            log "Cleaning up edge services..."
            docker compose $compose_file down --volumes --remove-orphans
            ;;
        *)
            error "Unknown edge command: $command"
            show_edge_help
            ;;
    esac
}

# Handle all services commands
handle_all() {
    local compose_files="-f $CLOUD_COMPOSE_FILE -f $EDGE_COMPOSE_FILE"
    local command=$1
    shift || true

    case "$command" in
        "")
            show_all_help
            ;;
        up|down|start|stop|restart|build|ps)
            check_docker
            case "$command" in
                start)
                    log "Building and starting all services..."
                    docker compose $compose_files up --build "$@"
                    ;;
                *)
                    log "Running: docker compose $compose_files $command $@"
                    docker compose $compose_files "$command" "$@"
                    ;;
            esac
            ;;
        logs)
            check_docker
            if [ $# -eq 0 ]; then
                docker compose $compose_files logs -f
            else
                docker compose $compose_files logs -f "$@"
            fi
            ;;
        format)
            check_docker
            section "Formatting all code"
            log "Formatting Edge Admin..."
            docker compose $compose_files run --rm edge_admin mix format
            log "Formatting Edge Agent..."
            docker compose $compose_files run --rm edge_agent mix format
            log "All code formatted!"
            ;;
        lint)
            check_docker
            section "Linting all code"
            log "Linting Edge Admin..."
            docker compose $compose_files run --rm edge_admin mix lint
            log "Linting Edge Agent..."
            docker compose $compose_files run --rm edge_agent mix lint
            log "All code linted!"
            ;;
        test)
            check_docker
            section "Running all tests"
            log "Testing Edge Admin..."
            docker compose $compose_files run --rm edge_admin_test
            log "Testing Edge Agent..."
            docker compose $compose_files run --rm edge_agent_test
            log "All tests completed!"
            ;;
        quality)
            check_docker
            section "Running quality checks"
            log "Edge Admin quality checks..."
            docker compose $compose_files run --rm edge_admin mix quality
            log "Edge Agent quality checks..."
            docker compose $compose_files run --rm edge_agent mix quality
            log "All quality checks completed!"
            ;;
        security)
            check_docker
            section "Running security checks"
            log "Edge Admin security checks..."
            docker compose $compose_files run --rm edge_admin mix security
            log "Edge Agent security checks..."
            docker compose $compose_files run --rm edge_agent mix security
            log "All security checks completed!"
            ;;
        db:setup)
            check_docker
            section "Setting up all databases"
            log "Setting up Edge Admin database..."
            docker compose $compose_files run --rm edge_admin mix ecto.setup
            log "Setting up Edge Agent database..."
            docker compose $compose_files run --rm edge_agent mix ecto.setup
            log "All databases set up!"
            ;;
        db:reset)
            check_docker
            warn "This will delete ALL data! Press Ctrl+C to cancel, Enter to continue..."
            read -r
            section "Resetting all databases"
            log "Resetting Edge Admin database..."
            docker compose $compose_files run --rm edge_admin mix ecto.reset
            log "Resetting Edge Agent database..."
            docker compose $compose_files run --rm edge_agent mix ecto.reset
            log "All databases reset!"
            ;;
        clean)
            check_docker
            log "Cleaning up all services..."
            docker compose $compose_files down --volumes --remove-orphans
            docker system prune -f
            log "Cleanup complete!"
            ;;
        *)
            error "Unknown all command: $command"
            show_all_help
            ;;
    esac
}

# Initialize
validate_env

# Main command routing
case "$1" in
    check)
        log "Checking Docker installation..."
        docker --version
        docker compose version
        log "Environment: $ENV"
        log "Cloud compose: $CLOUD_COMPOSE_FILE"
        log "Edge compose: $EDGE_COMPOSE_FILE"
        validate_compose_file "$CLOUD_COMPOSE_FILE"
        validate_compose_file "$EDGE_COMPOSE_FILE"
        log "All compose files found!"
        ;;
    cloud)
        shift
        validate_compose_file "$CLOUD_COMPOSE_FILE"
        handle_cloud "$@"
        ;;
    edge)
        shift
        validate_compose_file "$EDGE_COMPOSE_FILE"
        handle_edge "$@"
        ;;
    all)
        shift
        validate_compose_file "$CLOUD_COMPOSE_FILE"
        validate_compose_file "$EDGE_COMPOSE_FILE"
        handle_all "$@"
        ;;
    ""|help|--help|-h)
        show_help
        ;;
    *)
        error "Unknown scope: $1"
        show_help
        exit 1
        ;;
esac
