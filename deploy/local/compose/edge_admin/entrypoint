#!/bin/bash
# deploy/local/compose/edge_admin/entrypoint

set -o errexit
set -o pipefail
set -o nounset

echo "=== Edge Admin Entrypoint ==="

# Ensure /etc/netclient directory exists with proper permissions
# (Mitigation for netclient TOCTOU race condition)
mkdir -p /etc/netclient
chmod 0775 /etc/netclient

# Check if running with NET_ADMIN capability (required for VPN)
if ! capsh --print | grep -q "Current: .*cap_net_admin"; then
    echo "WARNING: NET_ADMIN capability not detected. VPN operations may fail."
    echo "Ensure container is started with --cap-add=NET_ADMIN"
fi

# WG_QUICK_USERSPACE_IMPLEMENTATION controls netclient's WireGuard backend.
# This fork only checks for "wireguard-go" — everything else uses kernel WireGuard.
#   "wireguard-go" → userspace wireguard-go (DERP relay support enabled)
#   unset/other    → kernel WireGuard module (better performance, no DERP)
_wg_val="${WG_QUICK_USERSPACE_IMPLEMENTATION:-}"
if [ "$_wg_val" = "wireguard-go" ]; then
    echo "WireGuard mode: wireguard-go (userspace, DERP enabled)"
elif [ -z "$_wg_val" ]; then
    echo "WireGuard mode: kernel (default)"
else
    echo "WireGuard mode: $_wg_val (unrecognised value — netclient will use kernel detection)"
fi
unset _wg_val

# Check if netclient is available
if ! command -v netclient &> /dev/null; then
    echo "ERROR: netclient not found in PATH"
    exit 1
fi

echo "Netclient version: $(netclient version 2>/dev/null || echo 'unknown')"

echo "All prerequisites ready, starting application..."
exec "$@"
