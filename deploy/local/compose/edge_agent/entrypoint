#!/bin/bash
# deploy/local/compose/edge_agent/entrypoint

set -o errexit
set -o pipefail
set -o nounset

echo "=== Edge Agent Entrypoint ==="

# Unified data directory — all persistent state lives here.
# DATA_DIR can be overridden via env; defaults to /app/data.
#   ${DATA_DIR}/agent/      — SQLite database
#   ${DATA_DIR}/vpn/        — netclient state (/etc/netclient symlinks here)
#   ${DATA_DIR}/ssh/        — SSH host keys (private; chmod 0700)
#   ${DATA_DIR}/ssh/users/  — :ssh.daemon's :user_dir (unused, but required)
DATA_DIR="${DATA_DIR:-/app/data}"

# Ensure unified data directory structure exists.
# Always create these — DATA_DIR may differ from the /app/data baked at build time
# (e.g. DATA_DIR=/app/data/test in the test container).
mkdir -p "${DATA_DIR}/vpn"
mkdir -p "${DATA_DIR}/ssh/users"

# /etc/netclient must be a symlink pointing to ${DATA_DIR}/vpn.
# Recreate if missing, not a symlink, or pointing at the wrong target.
if [ "$(readlink /etc/netclient 2>/dev/null)" != "${DATA_DIR}/vpn" ]; then
    echo "Updating /etc/netclient symlink → ${DATA_DIR}/vpn"
    rm -rf /etc/netclient
    ln -sfn "${DATA_DIR}/vpn" /etc/netclient
fi
chmod 0775 "${DATA_DIR}/vpn"

# SSH host keys are private — lock down system_dir to root-only.
# users/ stays world-traversable so :ssh.daemon's :user_dir lookups don't fail.
chmod 0700 "${DATA_DIR}/ssh"
chmod 0755 "${DATA_DIR}/ssh/users"

# Check if running in privileged mode (agent typically runs privileged for hostscript + VPN)
if [ -e /proc/1/ns/pid ] && [ "$(readlink /proc/1/ns/pid)" = "$(readlink /proc/self/ns/pid)" ]; then
    echo "Running in privileged mode: YES (full capabilities)"
elif capsh --print 2>/dev/null | grep -q "Current: .*cap_net_admin"; then
    echo "Running with NET_ADMIN capability (VPN will work, hostscript limited to chroot)"
else
    echo "WARNING: No privileged mode or NET_ADMIN capability detected"
    echo "VPN operations and hostscript may fail"
fi

# WG_QUICK_USERSPACE_IMPLEMENTATION controls netclient's WireGuard backend:
#   "wireguard-go" → userspace wireguard-go (DERP relay support enabled)
#   unset          → kernel WireGuard module (better performance, no DERP)
#   anything else  → treated as kernel mode by netclient
_wg_val="${WG_QUICK_USERSPACE_IMPLEMENTATION:-}"
if [ "$_wg_val" = "wireguard-go" ]; then
    echo "WireGuard mode: wireguard-go (userspace, DERP enabled)"
elif [ -z "$_wg_val" ]; then
    echo "WireGuard mode: kernel (default)"
else
    echo "WireGuard mode: $_wg_val (unrecognised value — netclient will use kernel detection)"
fi
unset _wg_val

# Check if netclient is available
if ! command -v netclient &> /dev/null; then
    echo "ERROR: netclient not found in PATH"
    exit 1
fi

echo "Netclient version: $(netclient version 2>/dev/null || echo 'unknown')"

# Check if hostscript is available (agent-specific utility)
if ! command -v hostscript &> /dev/null; then
    echo "WARNING: hostscript not found - command execution will fail"
fi

echo "All prerequisites ready, starting application..."
exec "$@"
