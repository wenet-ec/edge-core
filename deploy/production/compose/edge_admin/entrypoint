#!/bin/bash
# deploy/production/compose/edge_admin/entrypoint

set -o errexit
set -o pipefail
set -o nounset

# Set default PostgreSQL user if not provided
if [ -z "${POSTGRES_USER:-}" ]; then
    base_postgres_image_default_user='postgres'
    export POSTGRES_USER="${base_postgres_image_default_user}"
fi

# Function to wait for a service to be available
wait_for_service() {
    local host=$1
    local port=$2
    local service_name=$3
    
    echo "Waiting for ${service_name} to be available..."
    while ! nc -z "${host}" "${port}"; do
        >&2 echo "${service_name} is unavailable - sleeping"
        sleep 1
    done
    >&2 echo "${service_name} is available"
}

# Function to setup VPN connection
setup_vpn_connection() {
    echo "Setting up VPN connection..."
    
    # Wait for VPN wrapper to be available first
    wait_for_service "edge_vpn" "8081" "VPN Wrapper"
    
    # Start tailscaled daemon (using sudo since we need root for networking)
    echo "Starting tailscaled daemon..."
    
    # Ensure directories exist and are accessible - use || true to ignore errors if they exist
    sudo mkdir -p /var/run/tailscale || true
    sudo mkdir -p /var/cache/tailscale || true  
    sudo mkdir -p /var/lib/tailscale || true
    
    # Fix ownership
    sudo chown -R app:app /var/run/tailscale /var/cache/tailscale /var/lib/tailscale || true
    
    # Start tailscaled as root (required for VPN operations)
    sudo tailscaled --state=/var/lib/tailscale/tailscaled.state --socket=/var/run/tailscale/tailscaled.sock &
    sleep 3
    
    # Check if we're already authenticated and connected
    echo "Checking existing Tailscale status..."
    if sudo tailscale status 2>/dev/null | grep -q "edge-admin" && sudo tailscale status 2>/dev/null | grep -q "100\."; then
        echo "Already authenticated and connected, using existing state"
        return 0
    fi
    
    # Check if we have existing state and try to bring it up
    if [ -f "/var/lib/tailscale/tailscaled.state" ] && [ -s "/var/lib/tailscale/tailscaled.state" ]; then
        echo "Found existing Tailscale state, checking if it's valid..."
        
        # First, check if the state contains valid authentication
        # We'll try to get status and see if we're logged in
        sleep 2  # Give tailscaled time to read the state
        
        if sudo tailscale status 2>/dev/null | grep -q "Logged out"; then
            echo "Existing state is logged out, need new authentication..."
        elif sudo tailscale status 2>/dev/null | grep -q "edge-admin"; then
            echo "Found valid existing authentication, attempting to connect..."
            # Try to bring up the connection with existing auth
            if sudo tailscale up --login-server="${VPN_URL}" --accept-dns=false --hostname=edge-admin; then
                # Give it a moment and check if connection succeeded
                sleep 2
                if sudo tailscale status 2>/dev/null | grep -q "100\."; then
                    echo "Successfully reconnected using existing credentials"
                    return 0
                fi
            fi
            echo "Failed to reconnect with existing state, will get new auth..."
        else
            echo "Existing state is not usable, will get new authentication..."
        fi
    fi
    
    echo "Getting new VPN authentication..."
    
    # Step 1: Check if edge-admins user exists, create if not
    echo "Checking for edge-admins user..."
    USER_RESPONSE=$(curl -s "${VPN_WRAPPER_URL}/api/v1/user?name=edge-admins")
    
    if echo "${USER_RESPONSE}" | grep -q "edge-admins"; then
        echo "User edge-admins already exists"
        USER_ID=$(echo "${USER_RESPONSE}" | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)
    else
        echo "Creating edge-admins user..."
        CREATE_RESPONSE=$(curl -s -X POST "${VPN_WRAPPER_URL}/api/v1/user" \
            -H "Content-Type: application/json" \
            -d '{"name": "edge-admins"}')
        USER_ID=$(echo "${CREATE_RESPONSE}" | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)
    fi
    
    echo "User ID: ${USER_ID}"
    
    # Step 2: Get preauth key
    echo "Getting preauth key..."
    EXPIRATION=$(date -d "+1 hour" --iso-8601=seconds)

    PREAUTH_RESPONSE=$(curl -s -X POST "${VPN_WRAPPER_URL}/api/v1/preauthkey" \
        -H "Content-Type: application/json" \
        -d '{
            "user": "'"${USER_ID}"'", 
            "reusable": false, 
            "ephemeral": false,
            "expiration": "'"${EXPIRATION}"'"
        }')
    
    PREAUTH_KEY=$(echo "${PREAUTH_RESPONSE}" | grep -o '"key":"[^"]*"' | cut -d'"' -f4)
    
    if [ -z "${PREAUTH_KEY}" ]; then
        echo "ERROR: Failed to get preauth key"
        echo "Response: ${PREAUTH_RESPONSE}"
        exit 1
    fi

    echo "Preauth key obtained: ${PREAUTH_KEY}"
    
    # Step 3: Connect to VPN with new preauth key
    sudo tailscale up --login-server="${VPN_URL}" --authkey="${PREAUTH_KEY}" --accept-dns=false --hostname=edge-admin
}

# Main execution flow
echo "Starting Edge Admin setup..."

# Wait for PostgreSQL
wait_for_service "${POSTGRES_HOST}" "${POSTGRES_PORT}" "PostgreSQL"

# Setup VPN connection
setup_vpn_connection

if [ $? -eq 0 ]; then
    echo "Successfully connected to VPN"
    sudo tailscale status
else
    echo "ERROR: Failed to connect to VPN"
    exit 1
fi

echo "All prerequisites ready, starting application..."
exec "$@"