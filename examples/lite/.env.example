# examples/lite/.env.example
#
# Copy this file to .env and fill in your values before running.
# Lines marked REQUIRED must be set. Others have sensible defaults.
#
#   cp .env.example .env

# ==============================================================================
# DATABASE (PostgreSQL — Edge Admin)
# ==============================================================================

DB_HOST=edge_admin_db
DB_PORT=5432
DB_NAME=edge_admin
# REQUIRED — choose a name for your database
DB_USER=edge_admin_user
# REQUIRED — set a strong password
DB_PASSWORD=change-me
DB_POOL_SIZE=10
DB_SSL=false

# ==============================================================================
# EDGE ADMIN — web server & API
# ==============================================================================

API_PORT=44000
# REQUIRED — generate with: openssl rand -base64 48
SECRET_KEY_BASE=change-me-generate-with-openssl-rand-base64-48

# REQUIRED — omnipotent key (internal ops, fallback for all other keys)
MASTER_KEY=change-me

# Optional scoped keys (default to MASTER_KEY if unset)
# API_KEY=        # REST API endpoints — give to external API clients
# METRICS_KEY=    # metrics endpoints only — give to Prometheus scrapers
# PROXY_KEY=      # proxy tunnel endpoints — give to proxy clients
# MCP_KEY=        # MCP server endpoint — give to AI assistants

# Proxy ports (exposed via docker ports mapping)
HTTP_PROXY_PORT=43128
SOCKS5_PROXY_PORT=41080

# REQUIRED — public hostname(s) of this admin server, comma-separated
# Used when generating enrollment keys for agents
ADMIN_URLS=your-server-ip-or-domain.com

# Optional — self-hosted relay map server URL for DERP overlay.
# Leave unset to fall back to Tailscale's public relay network.
# See examples/relay/ to deploy your own relay infrastructure.
# DERP_MAP_URL=https://edge-relay-map-1.yourdomain.com/derpmap/default

# Cluster name for this admin instance (single cluster setup)
ADMIN_CLUSTER_NAME=a
ADMIN_CLUSTER_SUBNET=100.63.0.0/24
ADMIN_MAX_CAPACITY=200

# Allow agents to enroll without a pre-signed token (fine for homelab)
PUBLIC_ENROLLMENT_KEY_ENABLED=true

# Default cluster pre-created on boot so agents can enroll immediately
DEFAULT_CLUSTER_NAME=default

# WireGuard userspace mode (required when running admin in a container)
WG_QUICK_USERSPACE_IMPLEMENTATION=wireguard-go

# Erlang cookie for VPN cluster (single instance — these can stay as-is)
VPN_CLUSTER_COOKIE=homelab-cookie
VPN_CLUSTER_PORT=49125
ADMIN_DISCOVERY_PORT=44000

# ==============================================================================
# EDGE VPN
# ==============================================================================

# REQUIRED — public hostname of your Edge VPN server (same machine as admin)
SERVER_HOST=your-server-ip-or-domain.com
SERVER_HTTP_HOST=your-server-ip-or-domain.com
SERVER_API_CONN_STRING=your-server-ip-or-domain.com
NETMAKER_DEFAULT_DOMAIN=edge.internal

# REQUIRED — must match MASTER_KEY above
NETMAKER_API_URL=http://your-server-ip-or-domain.com:48081
NETMAKER_MASTER_KEY=change-me
MASTER_KEY=change-me

# Edge VPN UI admin account (bootstrapped on first run)
NETMAKER_SUPERADMIN_USERNAME=admin
# REQUIRED — set a strong password
NETMAKER_SUPERADMIN_PASSWORD=change-me

SERVER_NAME=edge-vpn
CORS_ALLOWED_ORIGIN=*
DISPLAY_KEYS=on
API_PORT=8081
DNS_MODE=on
COREDNS_ADDR=edge_vpn_dns:53
DISABLE_REMOTE_IP_CHECK=on
TELEMETRY=off
DEFAULT_DOMAIN=edge.internal
VERBOSITY=1

# WebSocket endpoint for Edge VPN broker (Mosquitto)
# REQUIRED — replace with your public hostname
SERVER_BROKER_ENDPOINT=ws://your-server-ip-or-domain.com:48083/mqtt
BROKER_ENDPOINT=ws://your-server-ip-or-domain.com:48083/mqtt
BROKER_TYPE=mosquitto

STUN_LIST=stun1.l.google.com:19302,stun2.l.google.com:19302,stun.stunprotocol.org:3478,stun.nextcloud.com:443,stun.netmaker.io:3478

# ==============================================================================
# EDGE AGENT (used in edge.yml)
# ==============================================================================

# Leave blank to use PUBLIC_ENROLLMENT_KEY_URL instead
ENROLLMENT_KEY=

# REQUIRED — URL to fetch a public enrollment key from your admin
# Replace with your actual admin IP/hostname and cluster name
PUBLIC_ENROLLMENT_KEY_URL=http://your-server-ip-or-domain.com:34000/api/v1/clusters/default/enrollment_keys/public

# Auto-update via Watchtower
SELF_UPDATE_ENABLED=true
WATCHTOWER_URL=http://localhost:58080
# REQUIRED — set a strong token
WATCHTOWER_HTTP_API_TOKEN=change-me
