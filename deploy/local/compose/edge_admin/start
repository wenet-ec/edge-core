#!/bin/bash
# deploy/local/compose/edge_admin/start

set -o errexit
set -o pipefail
set -o nounset

# Cleanup function to be called on container shutdown
cleanup() {
    echo "Received shutdown signal, cleaning up..."

    # Find all netclient daemon processes and send SIGTERM for graceful shutdown
    NETCLIENT_PIDS=$(pgrep -f "netclient daemon" || true)

    if [ -n "$NETCLIENT_PIDS" ]; then
        echo "Stopping netclient daemon processes: $NETCLIENT_PIDS"
        for pid in $NETCLIENT_PIDS; do
            kill -TERM "$pid" 2>/dev/null || true
        done

        # Wait for processes to exit gracefully (max 5 seconds)
        for i in {1..5}; do
            if ! pgrep -f "netclient daemon" > /dev/null; then
                echo "Netclient daemon stopped gracefully"
                break
            fi
            sleep 1
        done

        # Force kill if still running
        if pgrep -f "netclient daemon" > /dev/null; then
            echo "Force killing remaining netclient processes"
            pkill -9 -f "netclient daemon" 2>/dev/null || true
        fi
    else
        echo "No netclient daemon processes found"
    fi

    # Clean up routing policy rules (netmaker creates these with priorities 3000, 2500, 2000)
    echo "Cleaning up routing policy rules..."
    ip rule delete pref 3000 2>/dev/null || true
    ip rule delete pref 2500 2>/dev/null || true
    ip rule delete pref 2000 2>/dev/null || true

    # Remove WireGuard interface from host
    if ip link show netmaker &>/dev/null; then
        echo "Removing netmaker WireGuard interface..."
        ip link delete netmaker 2>/dev/null || true
    fi

    echo "Cleanup complete"
}

# Trap EXIT, INT, and TERM signals
trap cleanup EXIT INT TERM

# Wipe netclient credentials to start fresh every boot
echo "Wiping netclient credentials..."
rm -rf /etc/netclient/*

# Clean up any stale WireGuard interface from previous run
echo "Cleaning up stale WireGuard interface..."
ip link delete netmaker 2>/dev/null || true

mix deps.get
mix compile
mix ecto.migrate

# Bootstrap Netmaker superadmin
echo "Bootstrapping Netmaker superadmin..."
EDGE_ADMIN_MODE=task mix run --no-start -e "EdgeAdmin.Release.create_netmaker_superadmin()"

# Bootstrap default cluster
echo "Bootstrapping default cluster..."
EDGE_ADMIN_MODE=task mix run --no-start -e "EdgeAdmin.Release.create_default_cluster()"

# Start EPMD daemon for Erlang distribution
echo "Starting EPMD daemon..."
epmd -daemon

# Start netclient daemon in the background
echo "Starting netclient daemon..."
netclient daemon &
NETCLIENT_PID=$!
echo "Netclient daemon started with PID: $NETCLIENT_PID"

# Start the development server with hot reloading
echo "Starting Phoenix server..."
export PHX_SERVER=true
mix phx.server &
PHOENIX_PID=$!

# Wait for Phoenix server to exit
wait $PHOENIX_PID
