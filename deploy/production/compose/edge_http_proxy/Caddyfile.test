# deploy/production/compose/edge_http_proxy/Caddyfile.test

http://edge-vpn.localtest.me {
    reverse_proxy edge_vpn:8081
}

http://edge-vpn-ui.localtest.me {
    reverse_proxy edge_vpn_ui:80
}

http://edge-vpn-broker.localtest.me {
    reverse_proxy edge_vpn_broker:8083
}

http://edge-admin.localtest.me {
    reverse_proxy edge_admin:44000
}

http://edge-admin2.localtest.me {
    reverse_proxy edge_admin_2:44000
}

http://edge-admin3.localtest.me {
    reverse_proxy edge_admin_3:44000
}
