# deploy/local/.envs/.edge_admin

# =============================================================================
# Database
# =============================================================================
# DB_ADAPTER selects the engine at runtime — no rebuild needed.
#   postgres (default) — required for multi-admin Erlang clustering
#   sqlite             — single-instance only, no external DB needed
DB_ADAPTER=postgres

# --- PostgreSQL connection (DB_ADAPTER=postgres) ---
# Use either fragment form (the DB_* vars below) or URL form (DATABASE_URL).
# All-or-nothing per repo: when DATABASE_URL is set, every DB_* fragment is
# ignored. DB_POOL_SIZE / DB_SSL / DB_IPV6 always apply, regardless of form.

# DATABASE_URL=postgresql://edge_admin_user:edge_admin_password@edge_admin_db:5432/edge_admin_local
DB_HOST=edge_admin_db
DB_PORT=5432
DB_NAME=edge_admin_local
DB_USER=edge_admin_user
DB_PASSWORD=edge_admin_password

DB_POOL_SIZE=5
DB_SSL=false
# DB_IPV6=false

# --- SQLite connection (DB_ADAPTER=sqlite) ---
# SQLITE_DB_PATH=/app/data/edge/edge_admin.db  # default if unset

# --- Migrations (postgres only) ---
# Lock strategy. Default: pg_advisory_lock.
#   pg_advisory_lock  — Default. Needs a session-mode DB connection (does NOT
#                       work through PgBouncer transaction pooling — point
#                       migrations at the primary directly when behind one).
#   disabled          — No DB-level lock. Migrate sidecar serializes admins.
# DB_MIGRATION_LOCK=pg_advisory_lock

# --- Oban notifier (postgres only) ---
# Oban uses LISTEN/NOTIFY for cross-admin wake-ups, which session-pinned
# poolers (PgBouncer transaction mode, CNPG -pooler, Supabase pgbouncer)
# break. Set these to point at the primary directly when the main connection
# goes through a pooler. Required when DATABASE_URL is set (URL-form has no
# fallback). Falls back to DB_HOST/DB_PORT when unset (fragment form only).
# DATABASE_NOTIFIER_URL=postgresql://user:pass@edge-admin-db-rw:5432/edge_admin_production
# DB_NOTIFIER_HOST=edge-admin-db-rw
# DB_NOTIFIER_PORT=5432

# =============================================================================
# Phoenix / Web Server
# =============================================================================
API_PORT=44000
SECRET_KEY_BASE=zsIbO5eGH9IJ1p+E6M1a1VL4bIGrwLeTS8W7q8QDAOE/o3Ucy0si768bJxmF4A1Q
CORS_ALLOWED_ORIGINS=*
# Comma-separated list of allowed request headers, or `*` to mirror whatever
# the browser asks for in Access-Control-Request-Headers.
# Defaults to: authorization,content-type,x-request-id
# CORS_ALLOWED_HEADERS=authorization,content-type,x-request-id

# =============================================================================
# Basic Authentication (LiveDashboard)
# =============================================================================
# Protects /live_dashboard with HTTP Basic Auth.
# When BASIC_AUTH_ENABLED=true, both username and password must be set or the
# admin will raise on every dashboard request.
# When false (default), basic auth is skipped entirely.
BASIC_AUTH_ENABLED=false
# BASIC_AUTH_USERNAME=admin
# BASIC_AUTH_PASSWORD=admin

# =============================================================================
# Development & Debugging Tools
# =============================================================================
LIVE_DASHBOARD_ENABLED=true

# Enables SwaggerUI (/swaggerui), ReDoc (/redoc), AsyncAPI viewer (/asyncdoc),
# OpenAPI spec (/api/openapi), and AsyncAPI spec (/api/asyncapi).
# Set to false to test production behavior locally.
# API_DOCS_ENABLED=true

# =============================================================================
# Authentication & Authorization
# =============================================================================
AUTH_ENABLED=true

# Full admin access — required. Grants access to all management API endpoints.
MASTER_KEY=supersecretkey123456789

# Optional scoped keys. All default to MASTER_KEY if unset.
# API_KEY=      # REST API endpoints (nodes, commands, SSH, clusters)
# METRICS_KEY=  # Read-only: metrics endpoints
# PROXY_KEY=    # Proxy tunnel endpoints
# MCP_KEY=      # MCP server endpoint

# =============================================================================
# Proxy Servers
# =============================================================================
HTTP_PROXY_PORT=43128
SOCKS5_PROXY_PORT=41080

# Per-operation proxy timeouts (in milliseconds)
# PROXY_CONNECTION_TIMEOUT_MS=2000    # TCP connect to target host (default: 2s)
# PROXY_HANDSHAKE_TIMEOUT_MS=10000    # SOCKS5/HTTP proxy handshake (default: 10s)
# PROXY_READ_TIMEOUT_MS=10000         # Socket read (default: 10s)
# PROXY_RECV_TIMEOUT_MS=300000        # Forwarding loop inactivity — closes half-open connections (default: 5min)

# =============================================================================
# Observability
# =============================================================================
# Admin's own Prometheus metrics scrape target (host:port, no scheme).
METRICS_BASE_URL=edge_admin_a1:44000

# SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT_NAME=local

# --- PromEx Metrics Collection ---
# ADMIN_METRICS_ENABLED=true   # Set to false to disable all admin metrics collection (default: true)

# --- Grafana Dashboard Upload (optional) ---
# When GRAFANA_HOST is set, PromEx uploads all dashboards to Grafana on startup.
# Unset (default) → dashboards stay in priv/grafana_dashboards/ for manual import.
#
# Auth: set GRAFANA_AUTH_TOKEN (service account token — preferred) OR
#       GRAFANA_USERNAME + GRAFANA_PASSWORD (basic auth fallback).
#
# GRAFANA_HOST=http://localhost:3000
# GRAFANA_AUTH_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxx
# GRAFANA_USERNAME=admin
# GRAFANA_PASSWORD=admin
# GRAFANA_FOLDER_NAME=Edge Core          # Folder name in Grafana (default: "Edge Core")
# GRAFANA_UPLOAD_ON_START=true           # Upload dashboards on each boot (default: true)
# GRAFANA_ANNOTATE_LIFECYCLE=false       # Annotate app start/stop events (default: false)

# =============================================================================
# VPN / Netmaker
# =============================================================================

# --- Netmaker API Client ---
NETMAKER_API_URL=http://edge_vpn:8081
NETMAKER_MASTER_KEY=supersecretkey123456789

# --- Netmaker Superadmin ---
# Bootstraps the Netmaker UI admin account on first run.
NETMAKER_SUPERADMIN_USERNAME=admin
NETMAKER_SUPERADMIN_PASSWORD=admin

# --- Netclient API Scheme ---
# http  = local dev (no TLS certs)
# https = production default
NETMAKER_API_SCHEME=http

# --- Netmaker DNS Domain ---
# Appended to all admin/node hostnames (e.g. admin-abc123.nm.internal).
# Cannot be changed after nodes have enrolled — pick once.
# NETMAKER_DEFAULT_DOMAIN=nm.internal

# --- Edge Cluster Network Allocation ---
# Subnet prefix length for auto-generated cluster networks (24 = /24 = 254 usable hosts).
# CLUSTER_SUBNET_PREFIX=24

# CIDR pool from which cluster subnets are carved (CGNAT space by default).
# CLUSTER_AUTO_GENERATED_RANGES=100.64.0.0/10

# Slots reserved for admin gateway nodes (e.g. split-brain flooding) — tune to match admin instance count per core.
# ADMIN_SLOT_RESERVATION=10

# Slots reserved for node churn headroom (reconciliation re-adds, transient failures).
# NODE_SLOT_RESERVATION=10

# Pre-create a named default cluster so agents can enroll without specifying a cluster.
# `default` is reserved (used as a URL keyword on convenience routes) — pick any
# other valid name. Routes like POST /api/v1/clusters/default/enrollment_keys
# resolve to whichever cluster this variable names.
DEFAULT_CLUSTER_NAME=test
# DEFAULT_CLUSTER_SUBNET=100.64.0.0/24
# DEFAULT_CLUSTER_NODE_LIMIT=   # Max nodes allowed in the default cluster (unset = no limit)

# Allow agent enrollment without a signed token — dev/testing only, never production.
PUBLIC_ENROLLMENT_KEY_ENABLED=true

# Admin URLs for enrollment key generation and agent fallback (required).
ADMIN_URLS=http://localhost:4000

# DERP map server URL. Optional — leave unset to skip DERP overlay (Tailscale fallback).
# This is the map server that describes relay locations, NOT the relay server itself.
# Upfront decision: on first enrollment, agent doesn't have the map yet so VPN peer path
# won't work — registration falls back to HTTP via admin_fallback_urls. Agent gets the map
# after registering and converges on the same DERP. Adding/removing later has the same effect.
# DERP_MAP_URL=http://localhost:47713/derpmap/default

# =============================================================================
# Admin Cluster & Erlang Distribution
# =============================================================================
# Admins form an Erlang cluster over the VPN for HA coordination:
#   - syn distributed registry for cross-admin request routing
#   - Oban Global peer leader election (Cron/Lifeline run on leader only)
#   - periodic peer discovery and reconnection
# A single-instance setup still boots correctly with these set.

# Name suffix for the admin cluster VPN network.
# Prefixed internally → "admin-cluster-a". Suffix must be ≤16 chars.
# Must be identical across all admin instances in the same deployment.
ADMIN_CLUSTER_NAME=a

# IPv4 CIDR for the admin cluster VPN. Must not overlap with edge cluster ranges.
ADMIN_CLUSTER_SUBNET=100.63.0.0/24

# Maximum WireGuard peers this admin can sit in a mesh with — the operator-facing
# physical constraint. Counts both admin-mesh peers (= total_admins - 1) and edge-node
# peers. The system derives edge_node_capacity = max_wireguard_peers - admin_peer_count
# at runtime; that derived number is what cluster sharding uses.
ADMIN_MAX_WIREGUARD_PEERS=250

# Static WireGuard listen port for the admin VPN interface.
# By default WireGuard picks ports dynamically and negotiates the best path per peer.
# Pin this only on resource-constrained machines or heavily firewalled/NAT environments
# where dynamic port negotiation is unreliable or blocked — pinning trades flexibility
# for predictability at the cost of always using a fixed UDP port.
# When set explicitly, always takes precedence over StatefulSet auto-assignment.
# ADMIN_WIREGUARD_PORT=51821

# K8s StatefulSet: base WireGuard port for auto-assignment.
# When POD_INDEX is injected by the K8s Downward API, the start script computes:
#   ADMIN_WIREGUARD_PORT = ADMIN_WIREGUARD_PORT_BASE + POD_INDEX
# Pod 0 → 51820, pod 1 → 51821, pod 2 → 51822, etc.
# No-op when POD_INDEX is absent (Docker Compose / non-StatefulSet deployments).
# ADMIN_WIREGUARD_PORT_BASE=51820

# Shared Erlang cookie for VPN cluster — must be identical across all admin instances.
VPN_CLUSTER_COOKIE=local-cookie

# epmd port — default 44369, baked into the Dockerfile. Override here only if needed.
# ERL_EPMD_PORT=44369

# Fixed Erlang distribution port for VPN cluster (epmd replacement). Configured in vm.args.eex.
VPN_CLUSTER_PORT=49125

# Erlang net_ticktime (seconds). Failure detection window = 4 × this value (default 60 → 240s).
# Lower values detect dead nodes faster but risk false positives on transient network blips.
# Must be identical across all admin instances in the same Erlang cluster.
# ERL_NET_TICKTIME=60

# Port on which admin instances expose their discovery/health endpoint to each other.
ADMIN_DISCOVERY_PORT=44000


# =============================================================================
# Event Broker
# =============================================================================

# EVENT_BROKER_ENABLED=true
# CORE_NAME=                            # included in every envelope; defaults to "default"

# NATS:
# EVENT_BROKER_ADAPTER=nats
# EVENT_BROKER_NATS_URLS=nats://edge_event_broker_nats:4222   # comma-separated for cluster
# EVENT_BROKER_NATS_JETSTREAM=true                            # durable JetStream log (default: false)
# EVENT_BROKER_NATS_TOKEN=                                    # shared token
# EVENT_BROKER_NATS_USERNAME=                                 # username + password
# EVENT_BROKER_NATS_PASSWORD=
# EVENT_BROKER_NATS_NKEY_SEED=                                # NKey seed (standalone or with JWT)
# EVENT_BROKER_NATS_JWT=                                      # JWT credential, alongside NKEY_SEED

# Kafka / Redpanda:
# EVENT_BROKER_ADAPTER=kafka
# EVENT_BROKER_KAFKA_URLS=edge_event_broker_kafka:9092        # comma-separated host:port list for cluster
# EVENT_BROKER_KAFKA_USERNAME=
# EVENT_BROKER_KAFKA_PASSWORD=
# EVENT_BROKER_KAFKA_SASL_MECHANISM=plain                     # plain | scram_sha_256 | scram_sha_512
# EVENT_BROKER_KAFKA_SSL=true                                 # TLS, required for public/external brokers

# AMQP 0-9-1 (RabbitMQ / LavinMQ / AmazonMQ for RabbitMQ / CloudAMQP):
# EVENT_BROKER_ADAPTER=amqp091     # alias `rabbitmq` also accepted
# EVENT_BROKER_RABBITMQ_URL=amqp://edge_event_broker_rabbitmq:5672   # embed credentials: amqp://user:pass@host:port
# EVENT_BROKER_RABBITMQ_SSL=true                              # TLS, required for public/external brokers

# Redis:
# EVENT_BROKER_ADAPTER=redis
# EVENT_BROKER_REDIS_URL=redis://edge_event_broker_redis:6379   # embed credentials: redis://:pass@host:port
# EVENT_BROKER_REDIS_SSL=true                                 # TLS, required for public/external brokers

# MQTT (EMQX, Mosquitto, HiveMQ, AWS IoT, etc.):
# EVENT_BROKER_ADAPTER=mqtt
# EVENT_BROKER_MQTT_URL=edge_event_broker_mqtt:1883           # single host:port (no scheme)
# EVENT_BROKER_MQTT_QOS=1                                     # 0|1|2, default 1
# EVENT_BROKER_MQTT_JWT=                                      # JWT bearer (CONNECT password slot)
# EVENT_BROKER_MQTT_USERNAME=
# EVENT_BROKER_MQTT_PASSWORD=
# EVENT_BROKER_MQTT_SSL=true                                  # TLS, required for public/external brokers
# EVENT_BROKER_MQTT_CACERT_FILE=                              # custom CA bundle / pinning
# EVENT_BROKER_MQTT_CLIENT_CERT_FILE=                         # mTLS, requires SSL=true
# EVENT_BROKER_MQTT_CLIENT_KEY_FILE=                          # mTLS, requires SSL=true

# AWS SNS:
# EVENT_BROKER_ADAPTER=aws_sns
# EVENT_BROKER_AWS_SNS_REGION=us-east-1
# EVENT_BROKER_AWS_SNS_TOPIC_ARN_PREFIX=arn:aws:sns:us-east-1:000000000000:   # LocalStack uses account 000000000000
# EVENT_BROKER_AWS_SNS_ENDPOINT_URL=http://edge_event_broker_aws_sns:4566     # leave UNSET in prod
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_SESSION_TOKEN=                                          # optional, when assuming an IAM role via STS

# Google Cloud Pub/Sub:
# EVENT_BROKER_ADAPTER=google_pubsub
# EVENT_BROKER_GOOGLE_PUBSUB_PROJECT=edge-local               # any string works against the emulator
# EVENT_BROKER_GOOGLE_PUBSUB_TOPIC_ID_PREFIX=                 # optional, e.g. "edge-prod-"
# EVENT_BROKER_GOOGLE_PUBSUB_EMULATOR_HOST=edge_event_broker_google_pubsub:8085   # leave UNSET in prod
# GOOGLE_APPLICATION_CREDENTIALS=                             # service-account JSON path, real GCP only

# =============================================================================
# Background Workers & Schedulers
# =============================================================================

# --- Quantum LocalScheduler (runs on every instance) ---
# ADMIN_DISCOVERY_SCHEDULE=*/5 * * * *        # Scan VPN for other admin peers (default: every 5min)
# METADATA_RECOMPUTATION_SCHEDULE=* * * * *   # Recompute cluster ownership assignments (default: every 1min)
# NODE_HEALTH_CHECK_SCHEDULE=* * * * *           # Ping owned nodes to detect unhealthy status (default: every 1min)
# NODE_HEALTH_CHECK_CONCURRENCY=100
# EXECUTION_DELIVERY_SCHEDULE=* * * * *        # Deliver pending commands to agents (default: every 1min)
# EXECUTION_EXPIRATION_SCHEDULE=* * * * *      # Sweep and expire stale command executions (default: every 1min)

# Periodic netclient pull — decoupled from reconciliation, independent consistency backstop.
# VPN_CONFIG_SYNC_SCHEDULE=*/5 * * * *
# Disable on severely resource-starved machines where interface resets cascade into failures.
# VPN_CONFIG_SYNC_ENABLED=true

# Zombie Admin Cleanup — weak leader only, reduces duplicate work across admin instances.
# ZOMBIE_ADMIN_CLEANUP_SCHEDULE=*/30 * * * *
# ZOMBIE_ADMIN_CHECKIN_THRESHOLD_MINUTES=120

# Admin-cluster membership startup — per-step wait budget (seconds) before
# the admin gives up and crashes the supervision tree. Applies independently
# to "wait for Netmaker host registration" and "wait for netclient to join
# the admin VPN network." Bump up if Netmaker is slow on this deployment.
# MEMBERSHIP_JOIN_TIMEOUT_SECONDS=60

# --- Oban Cron (job inserted by leader; any instance competes to execute) ---

# Cluster Reconciliation: heals drift between DB and Netmaker
# CLUSTER_RECONCILIATION_ENABLED=true
# CLUSTER_RECONCILIATION_SCHEDULE=0 */6 * * *  # default: every 6 hours

# Rogue Host Eviction: delete hosts in a cluster network with no DB record
# Disable temporarily if you need direct Netmaker access (e.g. manual debugging).
# EVICT_ROGUE_HOSTS=true

# Execution Pruning: periodic deletion of finalised command_executions.
# Disabled by default — set EXECUTION_PRUNING_ENABLED=true to opt in. The cron
# entry is always registered; the worker no-ops when disabled. In-flight rows
# (pending, sent) and unsettled cancelled/expired rows (nil exit_code, agent
# may still report back) are never deleted regardless of age.
# EXECUTION_PRUNING_ENABLED=false
# EXECUTION_PRUNING_SCHEDULE=0 0 * * *   # default: daily at 00:00
# EXECUTION_RETENTION_DAYS=30            # default: 30 days

# --- HTTP Timeouts for Agent Communication ---
# HEALTH_CHECK_TIMEOUT_MS=10000       # Health check pings (every minute, all owned nodes)
# METRICS_SCRAPE_TIMEOUT_MS=10000     # Metrics scraping from agent exporters
# COMMAND_DELIVERY_TIMEOUT_MS=10000   # Command delivery to agents
