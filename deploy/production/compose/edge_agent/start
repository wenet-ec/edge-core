#!/bin/bash
# deploy/production/compose/edge_agent/start

set -o errexit
set -o pipefail
set -o nounset

# Cleanup function to be called on container shutdown
cleanup() {
    echo "Received shutdown signal, cleaning up..."

    # Find all netclient daemon processes and send SIGTERM for graceful shutdown.
    # On clean exit netclient restores /etc/resolv.conf from its backup itself.
    NETCLIENT_PIDS=$(pgrep -f "netclient daemon" || true)

    if [ -n "$NETCLIENT_PIDS" ]; then
        echo "Stopping netclient daemon processes: $NETCLIENT_PIDS"
        for pid in $NETCLIENT_PIDS; do
            kill -TERM "$pid" 2>/dev/null || true
        done

        # Wait for processes to exit gracefully (max 5 seconds)
        for i in {1..5}; do
            if ! pgrep -f "netclient daemon" > /dev/null; then
                echo "Netclient daemon stopped gracefully"
                break
            fi
            sleep 1
        done

        # Force kill if still running
        if pgrep -f "netclient daemon" > /dev/null; then
            echo "Force killing remaining netclient processes"
            pkill -9 -f "netclient daemon" 2>/dev/null || true
        fi
    else
        echo "No netclient daemon processes found"
    fi

    # Clean up routing policy rules (netmaker creates these with priorities 3000, 2500, 2000)
    echo "Cleaning up routing policy rules..."
    ip rule delete pref 3000 2>/dev/null || true
    ip rule delete pref 2500 2>/dev/null || true
    ip rule delete pref 2000 2>/dev/null || true

    # Remove WireGuard interface from host
    if ip link show netmaker &>/dev/null; then
        echo "Removing netmaker WireGuard interface..."
        ip link delete netmaker 2>/dev/null || true
    fi

    echo "Cleanup complete"
}

# Trap EXIT, INT, and TERM signals
trap cleanup EXIT INT TERM

echo "Running migrations..."
/app/bin/migrate

# Clean up any stale WireGuard interface from previous run
echo "Cleaning up stale WireGuard interface..."
ip link delete netmaker 2>/dev/null || true

# In production the agent runs with network_mode: host and /etc/resolv.conf
# bind-mounted from the host (see production compose), so netclient writes
# directly to the host's DNS config. netclient owns the backup/restore
# lifecycle - we only need to handle the one case it can't handle itself:
# unclean shutdown (SIGKILL/OOM) where resolv.conf still has the netmaker header
# but the backup was already deleted by a prior clean shutdown. netclient's
# Init() would crash trying to read the missing backup, so we re-seed it.
RESOLV_TARGET=$(readlink -f /etc/resolv.conf 2>/dev/null || echo /etc/resolv.conf)
BACKUP=/etc/netmaker-resolv.backup.conf
if grep -q "generated by netmaker" "$RESOLV_TARGET" 2>/dev/null && [ ! -f "$BACKUP" ]; then
    echo "Unclean shutdown detected: seeding resolv.conf backup so netclient can start..."
    cp "$RESOLV_TARGET" "$BACKUP"
fi

# Start netclient daemon in the background
echo "Starting netclient daemon..."
netclient daemon &
NETCLIENT_PID=$!
echo "Netclient daemon started with PID: $NETCLIENT_PID"

# Give netclient a head start to initialize
echo "Waiting for netclient to initialize..."
sleep 5

echo "Starting server..."
/app/bin/server &
SERVER_PID=$!

# Wait for server to exit
wait $SERVER_PID
