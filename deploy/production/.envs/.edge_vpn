# deploy/production/.envs/.edge_vpn
SERVER_NAME=production-edge-vpn
SERVER_HOST=edge-vpn.yourdomain.com
SERVER_HTTP_HOST=edge-vpn.yourdomain.com
MASTER_KEY=supersecretkey123456789
CORS_ALLOWED_ORIGIN=*
DATABASE=postgres
SQL_HOST=edge_vpn_db
SQL_PORT=5432
SQL_USER=edge_vpn
SQL_PASS=edge_vpn123
SQL_DB=edge_vpn
SQL_SSL_MODE=disable
API_PORT=8081
TELEMETRY=off
SERVER_BROKER_ENDPOINT=wss://edge-vpn-broker.yourdomain.com/mqtt
BROKER_ENDPOINT=wss://edge-vpn-broker.yourdomain.com/mqtt
BROKER_TYPE=emqx
EMQX_REST_ENDPOINT=http://edge_vpn_broker:18083
MQ_USERNAME=admin
MQ_PASSWORD=edge_vpn123
VERBOSITY=1
STUN_SERVERS=stun1.l.google.com:19302,stun2.l.google.com:19302,stun.stunprotocol.org:3478,stun.nextcloud.com:443,stun.netmaker.io:3478
SERVER_API_CONN_STRING=edge-vpn.yourdomain.com
DEFAULT_DOMAIN=nm.internal
