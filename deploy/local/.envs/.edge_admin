# deploy/local/.envs/.edge_admin

# Server configuration
CORS_ALLOWED_ORIGINS=*
API_PORT=44000
SECRET_KEY_BASE=zsIbO5eGH9IJ1p+E6M1a1VL4bIGrwLeTS8W7q8QDAOE/o3Ucy0si768bJxmF4A1Q
SESSION_KEY=edge_admin
SESSION_SIGNING_SALT=FUYY5L041VshhwCep1OyX+vu4imud8+63+kLzupf7lrqlkiztQWQjFcJLgCLalXp

# Authentication configuration
AUTH_ENABLED=true
MASTER_KEY=supersecretkey123456789
# METRICS_KEY=  # Optional: Scoped key for metrics endpoints (defaults to MASTER_KEY)

# Database configuration
DB_HOST=edge_admin_db
DB_PORT=5432
DB_NAME=edge_admin_local
DB_USER=edge_admin_user
DB_PASSWORD=edge_admin_password
DB_POOL_SIZE=10
DB_SSL=false

# Telemetry UI configuration
TELEMETRY_UI_SHARE_KEY=DzbqdoAx/MGq8rM

# Basic Authentication
# BASIC_AUTH_USERNAME=
# BASIC_AUTH_PASSWORD=

# Sentry configuration
# Sentry requires an environment name (but not a DSN)
# SENTRY_DSN=
SENTRY_ENVIRONMENT_NAME=local

# Netmaker
NETMAKER_API_URL=http://edge_vpn:8081
NETMAKER_MASTER_KEY=supersecretkey123456789
NETMAKER_SUPERADMIN_USERNAME=admin
NETMAKER_SUPERADMIN_PASSWORD=admin
WG_QUICK_USERSPACE_IMPLEMENTATION=wireguard-go

# Metrics configuration
METRICS_STORAGE_URL=http://edge_metrics_storage:8428

# Default cluster
DEFAULT_CLUSTER_NAME=default
# DEFAULT_CLUSTER_SUBNET=100.64.0.0/24

# Ephemeral key cleanup configuration
EPHEMERAL_KEY_TTL_HOURS=168  # 7 days
EPHEMERAL_KEY_CLEANUP_SCHEDULE=0 0 * * *  # Daily at midnight
EPHEMERAL_KEY_CLEANUP_ENABLED=true

# Admin clustering configuration
ADMIN_CLUSTER_NAME=1  # Will be prefixed with "admin-cluster-" → admin-cluster-1 (max 16 chars for suffix)
ADMIN_CLUSTER_SUBNET=100.63.0.0/24  # IPv4 CIDR for admin cluster network (separate from edge clusters)
ADMIN_MAX_CAPACITY=200  # Maximum number of nodes this admin can handle
ERLANG_COOKIE=local-cookie  # Shared secret for Erlang distribution
ADMIN_DISCOVERY_PORT=44000  # Port to scan for admin discovery endpoint
NETMAKER_DEFAULT_DOMAIN=nm.internal  # DNS domain suffix for hostname construction
