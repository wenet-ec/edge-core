# examples/relay/Caddyfile
# Serves the relay map JSON at /derpmap/default (Tailscale convention).
# DERP_MAP_HOSTNAME is injected from the .env file via Docker Compose environment.

{env.DERP_MAP_HOSTNAME} {
    handle /derpmap/default {
        root * /srv
        rewrite * /derp-map.json
        file_server
        header Content-Type application/json
    }

    handle {
        respond 404
    }
}
