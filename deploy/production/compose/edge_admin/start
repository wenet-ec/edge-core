#!/bin/bash
# deploy/production/compose/edge_admin/start

set -o errexit
set -o pipefail
set -o nounset

# Cleanup function to be called on container shutdown
cleanup() {
    echo "Received shutdown signal, cleaning up..."

    # Signal only the netclient daemon WE started. Do NOT use pgrep/pkill
    # by name — if this container ever runs with `pid: host` (the agent
    # does), a name match would find every netclient daemon on the host
    # and tear them down with us.
    if [ -n "${NETCLIENT_PID:-}" ] && kill -0 "$NETCLIENT_PID" 2>/dev/null; then
        echo "Stopping netclient daemon (PID: $NETCLIENT_PID)..."
        kill -TERM "$NETCLIENT_PID" 2>/dev/null || true

        # Wait for it to exit gracefully (max 5 seconds)
        for _ in {1..5}; do
            if ! kill -0 "$NETCLIENT_PID" 2>/dev/null; then
                echo "Netclient daemon stopped gracefully"
                break
            fi
            sleep 1
        done

        # Force kill if still running
        if kill -0 "$NETCLIENT_PID" 2>/dev/null; then
            echo "Force killing netclient daemon (PID: $NETCLIENT_PID)"
            kill -9 "$NETCLIENT_PID" 2>/dev/null || true
        fi
    else
        echo "No netclient daemon to stop"
    fi

    # Clean up routing policy rules (netmaker creates these with priorities 3000, 2500, 2000)
    echo "Cleaning up routing policy rules..."
    ip rule delete pref 3000 2>/dev/null || true
    ip rule delete pref 2500 2>/dev/null || true
    ip rule delete pref 2000 2>/dev/null || true

    # Remove WireGuard interface from host
    if ip link show netmaker &>/dev/null; then
        echo "Removing netmaker WireGuard interface..."
        ip link delete netmaker 2>/dev/null || true
    fi

    echo "Cleanup complete"
}

# Wipe netclient credentials to start fresh every boot
echo "Wiping netclient credentials..."
rm -rf /etc/netclient/*

# Clean up any stale WireGuard interface from previous run
echo "Cleaning up stale WireGuard interface..."
ip link delete netmaker 2>/dev/null || true

echo "Running migrations..."
/app/bin/migrate

echo "Checking Cloak key rotation..."
/app/bin/rotate_cloak_key

echo "Bootstrapping Netmaker superadmin..."
/app/bin/create_netmaker_superadmin

echo "Bootstrapping default cluster..."
/app/bin/create_default_cluster

# Resolve WireGuard port for StatefulSet deployments.
# If POD_INDEX is set (injected by K8s Downward API), auto-compute the port
# from ADMIN_WIREGUARD_PORT_BASE + POD_INDEX — unless ADMIN_WIREGUARD_PORT is
# already explicitly set, which always takes precedence.
if [ -n "${POD_INDEX:-}" ] && [ -z "${ADMIN_WIREGUARD_PORT:-}" ]; then
    _base="${ADMIN_WIREGUARD_PORT_BASE:-51820}"
    export ADMIN_WIREGUARD_PORT=$(( _base + POD_INDEX ))
    echo "StatefulSet mode: POD_INDEX=${POD_INDEX}, ADMIN_WIREGUARD_PORT=${ADMIN_WIREGUARD_PORT} (base=${_base})"
    unset _base
fi

# Bootstrap is done — from here on we have side effects (netclient, epmd,
# wireguard interface) worth cleaning up on shutdown. Install the trap now so
# bootstrap failures don't trigger misleading "cleaning up" log noise.
trap cleanup EXIT INT TERM

# Start EPMD daemon for Erlang distribution (required for admin clustering).
# Resolve the erts-* path explicitly to avoid glob expansion ambiguity.
echo "Starting EPMD daemon..."
EPMD_BIN=$(ls -d /app/erts-*/bin/epmd 2>/dev/null | head -n1)
if [ -z "$EPMD_BIN" ]; then
    echo "ERROR: epmd binary not found under /app/erts-*/bin/" >&2
    exit 1
fi
"$EPMD_BIN" -daemon

# Tell netclient where to fetch the DERP map overlay.
# Admin has DERP_MAP_URL at start time (deploy-time config) — export directly.
# Must be set before netclient daemon starts; cannot be pushed into a running process.
if [ -n "${DERP_MAP_URL:-}" ]; then
    export DERP_MAP_URLS="${DERP_MAP_URL}"
fi

# Start netclient daemon in the background
echo "Starting netclient daemon..."
netclient daemon &
NETCLIENT_PID=$!
echo "Netclient daemon started with PID: $NETCLIENT_PID"

echo "Starting server..."
/app/bin/server &
SERVER_PID=$!

# Wait for either child to exit. If netclient dies, the server is unreachable
# from the mesh — bail out and let the orchestrator restart us. Disable
# errexit around `wait -n` so we can capture the exit code and propagate it.
set +e
wait -n $NETCLIENT_PID $SERVER_PID
EXIT_CODE=$?
set -e

if [ "$EXIT_CODE" -ne 0 ]; then
    echo "Child process exited with code $EXIT_CODE (netclient=$NETCLIENT_PID, server=$SERVER_PID)" >&2
fi

exit $EXIT_CODE
