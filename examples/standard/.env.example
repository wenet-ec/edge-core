# examples/standard/.env.example
#
# Copy this file to .env and fill in your values before running.
# Lines marked REQUIRED must be set. Others have sensible defaults.
#
#   cp .env.example .env

# ==============================================================================
# DATABASE — Edge Admin (shared by all 4 admin instances)
# ==============================================================================

DB_HOST=edge_admin_db
DB_PORT=5432
# REQUIRED
DB_NAME=edge_admin
# REQUIRED
DB_USER=edge_admin_user
# REQUIRED — set a strong password
DB_PASSWORD=change-me
DB_POOL_SIZE=15
DB_SSL=false

# ==============================================================================
# EDGE ADMIN — web server & API (shared by all instances)
# ==============================================================================

API_PORT=44000
# REQUIRED — generate with: openssl rand -base64 48
SECRET_KEY_BASE=change-me-generate-with-openssl-rand-base64-48

# REQUIRED — strong random key for authenticating API clients
MASTER_KEY=change-me

# Optional scoped keys (default to MASTER_KEY if unset)
# METRICS_KEY=    # give to Prometheus scrapers
# PROXY_KEY=      # give to proxy clients

# Proxy ports
HTTP_PROXY_PORT=43128
SOCKS5_PROXY_PORT=41080

# REQUIRED — public hostname(s) of ALL admin instances, comma-separated
# Agents use this list to discover and connect to an admin
ADMIN_URLS=your-server-ip-or-domain.com

# --- Cluster A VPN subnet (shared by a1 + a2) ---
# REQUIRED — must not overlap with cluster B or edge cluster ranges
ADMIN_A_CLUSTER_SUBNET=100.63.0.0/24

# --- Cluster B VPN subnet (shared by b1 + b2) ---
# REQUIRED — must not overlap with cluster A or edge cluster ranges
ADMIN_B_CLUSTER_SUBNET=100.63.1.0/24

# Max edge nodes each admin instance will own
ADMIN_MAX_CAPACITY=200

# Allow agents to enroll without a pre-signed token
PUBLIC_ENROLLMENT_KEY_ENABLED=true

# Default cluster pre-created on boot
DEFAULT_CLUSTER_NAME=default

# WireGuard userspace mode (required when running admin in a container)
WG_QUICK_USERSPACE_IMPLEMENTATION=wireguard-go

# Erlang cookie for VPN cluster — must be identical across all admin instances
# REQUIRED — set a strong random value
VPN_CLUSTER_COOKIE=change-me-strong-random-cookie
VPN_CLUSTER_PORT=49125
ADMIN_DISCOVERY_PORT=44000

# Observability
METRICS_BASE_URL=edge_admin_a1:44000
SENTRY_ENVIRONMENT_NAME=production
# SENTRY_DSN=https://...@sentry.io/...

# ==============================================================================
# EDGE VPN
# ==============================================================================

# REQUIRED — public hostname of your Edge VPN server
SERVER_HOST=your-server-ip-or-domain.com
SERVER_HTTP_HOST=your-server-ip-or-domain.com
SERVER_API_CONN_STRING=your-server-ip-or-domain.com
NETMAKER_DEFAULT_DOMAIN=edge.internal

# REQUIRED — must match MASTER_KEY above
NETMAKER_API_URL=http://your-server-ip-or-domain.com:48081
NETMAKER_MASTER_KEY=change-me

# Edge VPN UI admin account (bootstrapped on first run)
NETMAKER_SUPERADMIN_USERNAME=admin
# REQUIRED — set a strong password
NETMAKER_SUPERADMIN_PASSWORD=change-me

SERVER_NAME=edge-vpn
CORS_ALLOWED_ORIGIN=*
DISPLAY_KEYS=on
API_PORT=8081
DNS_MODE=on
COREDNS_ADDR=edge_vpn_dns:53
DISABLE_REMOTE_IP_CHECK=on
TELEMETRY=off
DEFAULT_DOMAIN=edge.internal
VERBOSITY=1

# REQUIRED — replace with your public hostname
# Uses EMQX WebSocket endpoint (wss:// for TLS, ws:// for plain)
SERVER_BROKER_ENDPOINT=ws://your-server-ip-or-domain.com:48083/mqtt
BROKER_ENDPOINT=ws://your-server-ip-or-domain.com:48083/mqtt
BROKER_TYPE=emqx

# REQUIRED — EMQX REST endpoint (internal container address)
EMQX_REST_ENDPOINT=http://edge_vpn_broker:18083
# REQUIRED — must match EMQX credentials below
MQ_USERNAME=admin
MQ_PASSWORD=change-me

STUN_LIST=stun1.l.google.com:19302,stun2.l.google.com:19302,stun.stunprotocol.org:3478,stun.nextcloud.com:443,stun.netmaker.io:3478

# ==============================================================================
# EDGE VPN DATABASE (PostgreSQL)
# ==============================================================================

# REQUIRED
VPN_DB_NAME=edge_vpn
# REQUIRED
VPN_DB_USER=edge_vpn
# REQUIRED — set a strong password
VPN_DB_PASSWORD=change-me

# Also used directly by Edge VPN server
SQL_HOST=edge_vpn_db
SQL_PORT=5432
SQL_USER=edge_vpn
SQL_PASS=change-me
SQL_DB=edge_vpn
SQL_SSL_MODE=disable
DATABASE=postgres

# ==============================================================================
# EMQX MQTT BROKER
# ==============================================================================

# REQUIRED — EMQX dashboard login
EMQX_DASHBOARD_USERNAME=admin
# REQUIRED — set a strong password (also set MQ_PASSWORD to match)
EMQX_DASHBOARD_PASSWORD=change-me

# REQUIRED — Erlang distribution cookie shared across all EMQX nodes in the cluster.
# Single-node: still required (Mria uses it internally).
# Multi-node: ALL nodes must have the same cookie or they will refuse to join.
EMQX_NODE_COOKIE=change-me-emqx-cookie

# Scaling to multiple EMQX nodes (optional — single node is fine to start):
# 1. Add more broker services in cloud.yml, each with a unique hostname.
# 2. Update EMQX_CLUSTER__STATIC__SEEDS in each service's environment block
#    to list all node names: "[edge-vpn-broker@node1, edge-vpn-broker@node2, ...]"
# 3. Use odd replica count (3 recommended) to avoid split-brain.
# 4. All other clustering env vars (DB_BACKEND, ROLE, AUTOHEAL, RPC) are
#    already set in cloud.yml and require no changes here.

# ==============================================================================
# METRICS (VictoriaMetrics / vmagent)
# ==============================================================================

# How long to keep metrics data (e.g. 7d, 30d, 1y)
METRICS_RETENTION_PERIOD=30d

# ==============================================================================
# EDGE AGENT (used in edge.yml)
# ==============================================================================

# Leave blank to use PUBLIC_ENROLLMENT_KEY_URL instead
ENROLLMENT_KEY=

# REQUIRED — URL to fetch a public enrollment key from your admin
PUBLIC_ENROLLMENT_KEY_URL=http://your-server-ip-or-domain.com:34000/api/v1/clusters/default/enrollment_keys/public

# Auto-update via Watchtower
SELF_UPDATE_ENABLED=true
WATCHTOWER_URL=http://localhost:58080
# REQUIRED — set a strong token
WATCHTOWER_HTTP_API_TOKEN=change-me
