#!/bin/bash
# deploy/local/compose/edge_agent/start-dev

set -o errexit
set -o pipefail
set -o nounset

# Function to get enrollment key from Edge Admin
get_enrollment_key() {
    echo "Getting enrollment key from Edge Admin..."
    
    ENROLLMENT_RESPONSE=$(curl -s -X POST "${EDGE_ADMIN_URL}/api/enrollment_keys" \
        -H "Content-Type: application/json")
    
    ENROLLMENT_KEY=$(echo "${ENROLLMENT_RESPONSE}" | grep -o '"key":"[^"]*"' | cut -d'"' -f4)
    
    if [ -z "${ENROLLMENT_KEY}" ]; then
        echo "ERROR: Failed to get enrollment key from Edge Admin"
        echo "Response: ${ENROLLMENT_RESPONSE}"
        exit 1
    fi
    
    echo "Successfully obtained enrollment key from Edge Admin"
    export ENROLLMENT_KEY="${ENROLLMENT_KEY}"
}

echo "Setting up Edge Agent..."

# Get enrollment key from Edge Admin
get_enrollment_key

# Only compile if _build directory is empty or deps changed
if [ ! -d "_build/dev" ] || [ "mix.lock" -nt "_build/dev" ]; then
    echo "Installing/updating dependencies..."
    mix deps.get
    echo "Compiling dependencies and application..."
    mix deps.compile
    mix compile
else
    echo "Dependencies and build are up to date, skipping compilation..."
fi

# Run migrations
echo "Running migrations..."
mix ecto.migrate

# Start the development server with hot reloading
echo "Starting Phoenix server..."
exec mix phx.server