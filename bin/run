            ;;
        *)
            error "Unknown edge command: $command"
            show_edge_help
            ;;
    esac
}

# Handle all services commands
handle_all() {
    local compose_files="-f $CLOUD_COMPOSE_FILE -f $EDGE_COMPOSE_FILE"
    local command=$1
    shift || true

    case "$command" in
        "")
            show_all_help
            ;;
        up|down|start|stop|restart|build|ps)
            check_docker
            case "$command" in
                start)
                    log "Building and starting all services..."
                    docker compose $compose_files up --build "$@"
                    ;;
                *)
                    log "Running: docker compose $compose_files $command $@"
                    docker compose $compose_files "$command" "$@"
                    ;;
            esac
            ;;
        logs)
            check_docker
            if [ $# -eq 0 ]; then
                docker compose $compose_files logs -f
            else
                docker compose $compose_files logs -f "$@"
            fi
            ;;
        format)
            check_docker
            section "Formatting all code"
            log "Formatting Nexmaker..."
            docker compose $compose_files run --rm --workdir /nexmaker edge_admin_a1 mix format
            log "Formatting Edge Admin..."
            docker compose $compose_files run --rm edge_admin_a1 mix format
            log "Formatting Edge Agent..."
            docker compose $compose_files run --rm edge_agent mix format
            log "All code formatted!"
            ;;
        lint)
            check_docker
            section "Linting all code"
            log "Linting Edge Admin..."
            docker compose $compose_files run --rm edge_admin_a1 mix lint
            log "Linting Edge Agent..."
            docker compose $compose_files run --rm edge_agent mix lint
            log "All code linted!"
            ;;
        test)
            check_docker
            section "Running all tests"
            log "Testing Edge Admin..."
            docker compose $compose_files run --rm edge_admin_test
            log "Testing Edge Agent..."
            docker compose $compose_files run --rm edge_agent_test
            log "All tests completed!"
            ;;
        quality)
            check_docker
            section "Running quality checks"
            log "Edge Admin quality checks..."
            docker compose $compose_files run --rm edge_admin_a1 mix quality
            log "Edge Agent quality checks..."
            docker compose $compose_files run --rm edge_agent mix quality
            log "All quality checks completed!"
            ;;
        security)
            check_docker
            section "Running security checks"
            log "Edge Admin security checks..."
            docker compose $compose_files run --rm edge_admin_a1 mix security
            log "Edge Agent security checks..."
            docker compose $compose_files run --rm edge_agent mix security
            log "All security checks completed!"
            ;;
        check)
            check_docker
            section "Running all checks"
            log "Edge Admin checks..."
            docker compose $compose_files run --rm edge_admin_a1 mix check
            log "Edge Agent checks..."
            docker compose $compose_files run --rm edge_agent mix check
            log "All checks completed!"
            ;;
        db:setup)
            check_docker
            section "Setting up all databases"
            log "Setting up Edge Admin database..."
            docker compose $compose_files run --rm edge_admin_a1 mix ecto.setup
            log "Setting up Edge Agent database..."
            docker compose $compose_files run --rm edge_agent mix ecto.setup
            log "All databases set up!"
            ;;
        db:reset)
            check_docker
            warn "This will delete ALL data! Press Ctrl+C to cancel, Enter to continue..."
            read -r
            section "Resetting all databases"
            log "Resetting Edge Admin database..."
            docker compose $compose_files run --rm edge_admin_a1 mix ecto.reset
            log "Resetting Edge Agent database..."
            docker compose $compose_files run --rm edge_agent mix ecto.reset
            log "All databases reset!"
            ;;
        clean)
            check_docker
            log "Cleaning up all services..."
            docker compose $compose_files down --volumes --remove-orphans
            docker system prune -f
            log "Cleanup complete!"
            ;;
        *)
            error "Unknown all command: $command"
            show_all_help
            ;;
    esac
}

# k8s constants
K8S_CLUSTER_NAME="edge-core"
K8S_HELMFILE="deploy/k8s/helmfile.test.yaml"
K8S_KIND_CONFIG="deploy/k8s/kind-config.yaml"
K8S_NAMESPACE="edge-core"
# Images to build locally and load into kind
# Format: "local-tag:dockerfile-path"
K8S_IMAGES=(
    "ghcr.io/wenet-ec/edge_admin:local:deploy/production/compose/edge_admin/Dockerfile"
)

check_k8s_tools() {
    if ! command -v kind &> /dev/null; then
        error "kind is not installed. Install: curl -Lo ./kind https://kind.sigs.k8s.io/dl/latest/kind-linux-amd64 && chmod +x kind && mv kind /usr/local/bin/"
    fi
    if ! command -v kubectl &> /dev/null; then
        error "kubectl is not installed"
    fi
    if ! command -v helmfile &> /dev/null; then
        error "helmfile is not installed"
    fi
    if ! command -v helm &> /dev/null; then
        error "helm is not installed"
    fi
}

k8s_cluster_exists() {
    kind get clusters 2>/dev/null | grep -q "^${K8S_CLUSTER_NAME}$"
}

show_k8s_help() {
    echo -e "${BLUE}k8s Test Cluster Commands${NC}"
    echo "Manages: kind cluster + Helm/Helmfile stack (edge-admin, edge-vpn, postgres, emqx)"
    echo ""
    echo "Usage: ./bin/run k8s <command> [options]"
    echo ""
    echo -e "${YELLOW}Cluster Lifecycle:${NC}"
    echo "  up                     - Create cluster, build images, load into kind, helmfile apply"
    echo "  down                   - Delete kind cluster (destroys everything)"
    echo "  build                  - Build images and load into kind (cluster must exist)"
    echo "  apply                  - helmfile apply only (cluster + images must exist)"
    echo "  apply -l name=<rel>    - helmfile apply for a specific release only"
    echo ""
    echo -e "${YELLOW}Inspection:${NC}"
    echo "  ps                     - kubectl get pods -n edge-core"
    echo "  status                 - kubectl get all -n edge-core"
    echo "  logs <pod>             - kubectl logs -n edge-core <pod>"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  ./bin/run k8s up"
    echo "  ./bin/run k8s down"
    echo "  ./bin/run k8s build"
    echo "  ./bin/run k8s apply"
    echo "  ./bin/run k8s apply -l name=edge-admin-a"
    echo "  ./bin/run k8s ps"
    echo "  ./bin/run k8s logs edge-admin-a-xxx-yyy"
}

k8s_build_and_load() {
    section "Building images and loading into kind"
    for entry in "${K8S_IMAGES[@]}"; do
        local image="${entry%%:deploy/*}"
        local dockerfile="deploy/${entry##*:deploy/}"
        log "Building $image from $dockerfile..."
        docker build -t "$image" -f "$dockerfile" .
        log "Loading $image into kind cluster '$K8S_CLUSTER_NAME'..."
        kind load docker-image "$image" --name "$K8S_CLUSTER_NAME"
        log "$image loaded."
    done
}

handle_k8s() {
    local command=$1
    shift || true

    case "$command" in
        "")
            show_k8s_help
            ;;
        up)
            check_docker
            check_k8s_tools
            if k8s_cluster_exists; then
                warn "kind cluster '$K8S_CLUSTER_NAME' already exists — skipping creation."
            else
                log "Creating kind cluster '$K8S_CLUSTER_NAME'..."
                kind create cluster --name "$K8S_CLUSTER_NAME" --config "$K8S_KIND_CONFIG"
            fi
            k8s_build_and_load
            log "Installing CNPG operator (step 1/2)..."
            helmfile apply -f "$K8S_HELMFILE" -l name=cnpg-operator
            log "Waiting for CNPG operator pod to be ready..."
            kubectl rollout status deployment/cnpg-operator-cloudnative-pg -n edge-core --timeout=120s
            log "Waiting for CNPG webhook to accept connections (webhook cert provisioning)..."
            for i in $(seq 1 30); do
                if kubectl get clusters.postgresql.cnpg.io --all-namespaces >/dev/null 2>&1; then
                    log "CNPG webhook is ready."
                    break
                fi
                if [ "$i" -eq 30 ]; then
                    error "CNPG webhook did not become ready in time."
                fi
                sleep 5
            done
            log "Applying infra releases (step 2/3): DBs, EMQX, edge-vpn..."
            helmfile apply -f "$K8S_HELMFILE" -l name=edge-admin-db
            helmfile apply -f "$K8S_HELMFILE" -l name=edge-vpn-db
            helmfile apply -f "$K8S_HELMFILE" -l name=edge-vpn-broker
            helmfile apply -f "$K8S_HELMFILE" -l name=edge-vpn
            log "Waiting for edge-vpn pod to be ready..."
            kubectl rollout status statefulset/edge-vpn -n "$K8S_NAMESPACE" --timeout=120s
            log "Applying Caddy reverse proxy..."
            helmfile apply -f "$K8S_HELMFILE" -l name=caddy
            kubectl rollout status deployment/caddy -n "$K8S_NAMESPACE" --timeout=60s
            log "Resolving Caddy ClusterIP for admin pod hostAliases..."
            CADDY_IP=$(kubectl get svc caddy -n "$K8S_NAMESPACE" -o jsonpath='{.spec.clusterIP}')
            log "Caddy ClusterIP: $CADDY_IP"
            log "Applying edge-admin releases (step 3/3)..."
            CADDY_HOST_ALIASES="hostAliases[0].ip=$CADDY_IP,hostAliases[0].hostnames[0]=edge-vpn.localtest.me,hostAliases[0].hostnames[1]=edge-vpn-broker.localtest.me"
            helmfile apply -f "$K8S_HELMFILE" -l name=edge-admin-a --set "$CADDY_HOST_ALIASES"
            helmfile apply -f "$K8S_HELMFILE" -l name=edge-admin-b --set "$CADDY_HOST_ALIASES"
            helmfile apply -f "$K8S_HELMFILE" -l name=edge-admin-proxy
            log "Waiting for edge-admin to be ready..."
            kubectl rollout status deployment/edge-admin-a -n "$K8S_NAMESPACE" --timeout=300s
            kubectl rollout status deployment/edge-admin-b -n "$K8S_NAMESPACE" --timeout=300s
            log "k8s test stack is up."
            ;;
        down)
            check_k8s_tools
            if k8s_cluster_exists; then
                log "Deleting kind cluster '$K8S_CLUSTER_NAME'..."
                kind delete cluster --name "$K8S_CLUSTER_NAME"
                log "Cluster deleted."
            else
                warn "kind cluster '$K8S_CLUSTER_NAME' does not exist."
            fi
            ;;
        build)
            check_docker
            check_k8s_tools
            if ! k8s_cluster_exists; then
                error "kind cluster '$K8S_CLUSTER_NAME' does not exist. Run './bin/run k8s up' first."
            fi
            k8s_build_and_load
            ;;
        apply)
            check_k8s_tools
            if ! k8s_cluster_exists; then
                error "kind cluster '$K8S_CLUSTER_NAME' does not exist. Run './bin/run k8s up' first."
            fi
            log "Running helmfile apply..."
            helmfile apply -f "$K8S_HELMFILE" "$@"
            ;;
        ps)
            check_k8s_tools
            kubectl get pods -n "$K8S_NAMESPACE"
            ;;
        status)
            check_k8s_tools
            kubectl get all -n "$K8S_NAMESPACE"
            ;;
        logs)
            check_k8s_tools
            if [ $# -eq 0 ]; then
                warn "Usage: ./bin/run k8s logs <pod-name>"
                exit 1
            fi
            kubectl logs -n "$K8S_NAMESPACE" "$@"
            ;;
        *)
            error "Unknown k8s command: $command"
            show_k8s_help
            ;;
    esac
}

# Initialize
validate_env

# Main command routing
case "$1" in
    check)
        log "Checking Docker installation..."
        docker --version
        docker compose version
        log "Environment: $ENV"
        if [ -n "$VARIANT" ]; then
            log "Variant: $VARIANT"
        fi
        log "Cloud compose: $CLOUD_COMPOSE_FILE"
        log "Edge compose: $EDGE_COMPOSE_FILE"
        validate_compose_file "$CLOUD_COMPOSE_FILE"
        validate_compose_file "$EDGE_COMPOSE_FILE"
        log "All compose files found!"
        ;;
    cloud)
        shift
        validate_compose_file "$CLOUD_COMPOSE_FILE"
        handle_cloud "$@"
        ;;
    edge)
        shift
        validate_compose_file "$EDGE_COMPOSE_FILE"
        handle_edge "$@"
        ;;
    all)
        shift
        validate_compose_file "$CLOUD_COMPOSE_FILE"
        validate_compose_file "$EDGE_COMPOSE_FILE"
        handle_all "$@"
        ;;
    k8s)
        shift
        handle_k8s "$@"
        ;;
    ""|help|--help|-h)
        show_help
        ;;
    *)
        error "Unknown scope: $1"
        show_help
        exit 1
        ;;
esac
