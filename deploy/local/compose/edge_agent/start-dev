#!/bin/bash
# deploy/local/compose/edge_agent/start-dev

set -o errexit
set -o pipefail
set -o nounset

# Source compilation optimization settings
if [ -f ".compile_opts" ]; then
    echo "Loading compilation optimizations..."
    source .compile_opts
fi

# Function to get enrollment key from Edge Admin
get_enrollment_key() {
    echo "Getting enrollment key from Edge Admin..."
    
    ENROLLMENT_RESPONSE=$(curl -s -X POST "${EDGE_ADMIN_URL}/api/enrollment_keys" \
        -H "Content-Type: application/json")
    
    ENROLLMENT_KEY=$(echo "${ENROLLMENT_RESPONSE}" | grep -o '"key":"[^"]*"' | cut -d'"' -f4)
    
    if [ -z "${ENROLLMENT_KEY}" ]; then
        echo "ERROR: Failed to get enrollment key from Edge Admin"
        echo "Response: ${ENROLLMENT_RESPONSE}"
        exit 1
    fi
    
    echo "Successfully obtained enrollment key from Edge Admin"
    export ENROLLMENT_KEY="${ENROLLMENT_KEY}"
}

echo "Setting up Edge Agent..."

# Get enrollment key from Edge Admin
get_enrollment_key

# Smart compilation check - handle optional mix.lock
SHOULD_COMPILE=false

if [ ! -d "_build/dev" ]; then
    echo "Build directory not found, compilation needed..."
    SHOULD_COMPILE=true
elif [ -f "mix.lock" ] && [ "mix.lock" -nt "_build/dev" ]; then
    echo "mix.lock is newer than build, compilation needed..."
    SHOULD_COMPILE=true
elif [ "mix.exs" -nt "_build/dev" ]; then
    echo "mix.exs is newer than build, compilation needed..."
    SHOULD_COMPILE=true
fi

if [ "$SHOULD_COMPILE" = true ]; then
    echo "Installing/updating dependencies..."
    mix deps.get
    echo "Compiling dependencies and application (using parallel compilation)..."
    ERL_MAX_PORTS=4096 mix deps.compile --parallel --all-warnings
    ERL_MAX_PORTS=4096 mix compile --parallel --all-warnings
else
    echo "Dependencies and build are up to date, skipping compilation..."
fi

# Run migrations
echo "Running migrations..."
mix ecto.migrate

# Start the development server with hot reloading
echo "Starting Phoenix server..."
exec mix phx.server