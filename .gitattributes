# Default behavior: automatically handle line endings
* text=auto

# Shell scripts should use LF and be executable
*.sh text eol=lf
bin/*.sh text eol=lf executable

# Batch files should use CRLF
*.{cmd,[cC][mM][dD]} text eol=crlf
*.{bat,[bB][aA][tT]} text eol=crlf

# Elixir files
*.{ex,exs} text eol=lf
*.{eex,heex,leex} text eol=lf

# Configuration files
*.{json,yml,yaml,toml} text eol=lf
*.md text eol=lf
Dockerfile* text eol=lf