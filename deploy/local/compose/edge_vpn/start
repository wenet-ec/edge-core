#!/bin/bash
# deploy/local/compose/edge_vpn/start

set -e

echo "Starting Edge VPN services..."

# Function to handle shutdown gracefully
cleanup() {
    echo "Shutting down services..."
    kill $HEADSCALE_PID $WRAPPER_PID 2>/dev/null || true
    wait
    echo "Services stopped."
}

# Set up signal handling
trap cleanup SIGTERM SIGINT

# Start Headscale in the background
echo "Starting Headscale on port 8080..."
/usr/local/bin/headscale serve &
HEADSCALE_PID=$!

# Wait a moment for Headscale to start up
sleep 3

# Verify Headscale is running
if ! kill -0 $HEADSCALE_PID 2>/dev/null; then
    echo "ERROR: Headscale failed to start"
    exit 1
fi

echo "Headscale started successfully (PID: $HEADSCALE_PID)"

# Start the Go wrapper service
echo "Starting VPN Wrapper on port 8081..."
cd /app
./edge_vpn_wrapper &
WRAPPER_PID=$!

# Wait a moment for the wrapper to start
sleep 2

# Verify wrapper is running
if ! kill -0 $WRAPPER_PID 2>/dev/null; then
    echo "ERROR: VPN Wrapper failed to start"
    kill $HEADSCALE_PID 2>/dev/null || true
    exit 1
fi

echo "VPN Wrapper started successfully (PID: $WRAPPER_PID)"
echo "Both services are running:"
echo "  - Headscale: http://localhost:8080"
echo "  - VPN Wrapper: http://localhost:8081"

# Wait for either process to exit
wait