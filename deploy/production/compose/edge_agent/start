#!/bin/bash
# deploy/production/compose/edge_agent/start

set -o errexit
set -o pipefail
set -o nounset

# Cleanup function to be called on container shutdown
cleanup() {
    echo "Received shutdown signal, cleaning up..."

    # Restore the resolv.conf backup so netclient can reset DNS cleanly on shutdown.
    # Without this netclient logs "error resetting dns config: ...backup.conf: no such file"
    # because it consumed/removed the backup during its own DNS setup.
    RESOLV_TARGET=$(readlink -f /etc/resolv.conf 2>/dev/null || echo /etc/resolv.conf)
    cp "$RESOLV_TARGET" /etc/netmaker-resolv.backup.conf 2>/dev/null || true

    # Find all netclient daemon processes and send SIGTERM for graceful shutdown
    NETCLIENT_PIDS=$(pgrep -f "netclient daemon" || true)

    if [ -n "$NETCLIENT_PIDS" ]; then
        echo "Stopping netclient daemon processes: $NETCLIENT_PIDS"
        for pid in $NETCLIENT_PIDS; do
            kill -TERM "$pid" 2>/dev/null || true
        done

        # Wait for processes to exit gracefully (max 5 seconds)
        for i in {1..5}; do
            if ! pgrep -f "netclient daemon" > /dev/null; then
                echo "Netclient daemon stopped gracefully"
                break
            fi
            sleep 1
        done

        # Force kill if still running
        if pgrep -f "netclient daemon" > /dev/null; then
            echo "Force killing remaining netclient processes"
            pkill -9 -f "netclient daemon" 2>/dev/null || true
        fi
    else
        echo "No netclient daemon processes found"
    fi

    # Clean up routing policy rules (netmaker creates these with priorities 3000, 2500, 2000)
    echo "Cleaning up routing policy rules..."
    ip rule delete pref 3000 2>/dev/null || true
    ip rule delete pref 2500 2>/dev/null || true
    ip rule delete pref 2000 2>/dev/null || true

    # Remove WireGuard interface from host
    if ip link show netmaker &>/dev/null; then
        echo "Removing netmaker WireGuard interface..."
        ip link delete netmaker 2>/dev/null || true
    fi

    echo "Cleanup complete"
}

# Trap EXIT, INT, and TERM signals
trap cleanup EXIT INT TERM

echo "Running migrations..."
/app/bin/migrate

# Clean up any stale WireGuard interface from previous run
echo "Cleaning up stale WireGuard interface..."
ip link delete netmaker 2>/dev/null || true

# Recover resolv.conf state before starting netclient.
#
# netclient owns resolv.conf while running: it backs up the original to
# /etc/netmaker-resolv.backup.conf, writes its own header+nameserver, and
# restores the backup on clean shutdown. Two failure modes exist:
#
# 1. Unclean shutdown (SIGKILL, down -v): resolv.conf has the netmaker header
#    but the backup is gone. netclient sees ownedByUs=true, tries to restore
#    from the missing backup → Fatal crash.
#    Fix: strip the netmaker header from resolv.conf so netclient sees a clean
#    file and takes ownership from scratch, then seed a plain backup.
#
# 2. Clean state (first boot or after successful shutdown): resolv.conf has no
#    netmaker header. netclient will back it up itself on first write. But we
#    pre-seed the backup now anyway so the shutdown cleanup() always has a file
#    to restore from even if netclient never gets to write one.
RESOLV_TARGET=$(readlink -f /etc/resolv.conf 2>/dev/null || echo /etc/resolv.conf)
BACKUP=/etc/netmaker-resolv.backup.conf

if grep -q "generated by netmaker" "$RESOLV_TARGET" 2>/dev/null && [ ! -f "$BACKUP" ]; then
    # Unclean shutdown: extract the original nameserver lines netclient appended
    # after its header and restore resolv.conf to a plain file, then seed backup.
    echo "Recovering from unclean shutdown: resetting stale netmaker resolv.conf..."
    grep -v "^#\|^$\|^search" "$RESOLV_TARGET" > "$BACKUP" 2>/dev/null || printf 'nameserver 1.1.1.1\n' > "$BACKUP"
    cp "$BACKUP" "$RESOLV_TARGET"
else
    # Clean state: pre-seed backup from current resolv.conf so shutdown cleanup
    # always finds it, regardless of whether netclient wrote it first.
    cp "$RESOLV_TARGET" "$BACKUP" 2>/dev/null || true
fi

# Start netclient daemon in the background
echo "Starting netclient daemon..."
netclient daemon &
NETCLIENT_PID=$!
echo "Netclient daemon started with PID: $NETCLIENT_PID"

# Give netclient a head start to initialize
echo "Waiting for netclient to initialize..."
sleep 5

echo "Starting server..."
/app/bin/server &
SERVER_PID=$!

# Wait for server to exit
wait $SERVER_PID
