# deploy/local/.envs/.edge_agent

# =============================================================================
# VPN Enrollment
# =============================================================================
# Exactly one of ENROLLMENT_KEY or PUBLIC_ENROLLMENT_KEY_URLS must be set.
# ENROLLMENT_KEY is a static signed token (preferred for production).
# PUBLIC_ENROLLMENT_KEY_URLS is a comma-separated list of admin URLs to try
# in order at boot. Any admin can mint a key (shared Postgres), so the list
# is a pure availability fallback.
ENROLLMENT_KEY=
PUBLIC_ENROLLMENT_KEY_URLS=http://localhost:4000/api/v1/clusters/default/enrollment_keys/public

# Path to a local file containing the enrollment key (alternative to the above).
# PUBLIC_ENROLLMENT_KEY_PATH=/etc/edge/enrollment_key

# =============================================================================
# Self-Update (Watchtower)
# =============================================================================
SELF_UPDATE_ENABLED=true
WATCHTOWER_URL=http://localhost:58080
WATCHTOWER_HTTP_API_TOKEN=local-dev-token

# =============================================================================
# Web Server / API
# =============================================================================
# API_PORT=44000          # Agent HTTP API port (default: 44000)

# =============================================================================
# Ports
# =============================================================================
# SSH_PORT=40022                    # Embedded SSH server (default: 40022)
# HOST_METRICS_PORT=49100           # Node exporter scrape port (default: 49100)
# WIREGUARD_METRICS_PORT=49586      # WireGuard exporter scrape port (default: 49586)
# HTTP_PROXY_PORT=43128             # HTTP/CONNECT proxy (default: 43128)
# SOCKS5_PROXY_PORT=41080           # SOCKS5 proxy (default: 41080)
# AGENT_WIREGUARD_PORT=             # Static WireGuard listen port (optional; useful behind NAT)

# =============================================================================
# Admin Discovery
# =============================================================================
# Port that admin instances expose their discovery endpoint on.
# Must match ADMIN_DISCOVERY_PORT in the admin env.
# ADMIN_DISCOVERY_PORT=44000

# =============================================================================
# Node Identity
# =============================================================================
# USE_RANDOM_ID=false   # Use a random UUID instead of a stable hardware-derived ID.
#                       # Enable only for ephemeral/test agents.

# =============================================================================
# Node Aliases
# =============================================================================
# Friendly DNS names for this node (comma-separated). Best-effort — conflicts silently ignored.
# Each alias becomes node-{alias}.cluster-{cluster}.{domain} in the VPN mesh.
ALIASES=test

# =============================================================================
# Proxy Security
# =============================================================================
# Comma-separated lists for proxy access control (optional).
# PROXY_BLOCKED_PORTS=            # Block specific destination ports
# PROXY_CUSTOM_BLOCKED_HOSTS=     # Block specific destination hostnames
# PROXY_CUSTOM_ALLOWED_HOSTS=     # Allowlist: if set, only these hosts are reachable

# =============================================================================
# Authentication
# =============================================================================
# AGENT_METRICS_AUTH_ENABLED=true     # Require auth on metrics scrape endpoints (default: true)
# PROXY_SERVERS_AUTH_ENABLED=true     # Require auth on proxy endpoints (default: true)

# =============================================================================
# HTTP Timeouts (agent → admin communication)
# =============================================================================
# ADMIN_CALL_TIMEOUT_MS=10000         # Registration, command acks, health reporting, metrics push
# ADMIN_DISCOVERY_TIMEOUT_MS=5000     # Admin peer probing during discovery (parallel; geo-friendly)

# =============================================================================
# Proxy Server Timeouts
# =============================================================================
# Per-operation proxy timeouts (in milliseconds)
# PROXY_CONNECTION_TIMEOUT_MS=2000        # TCP connect to target host (default: 2s)
# PROXY_READ_TIMEOUT_MS=10000             # Socket read (default: 10s)
# PROXY_RECV_TIMEOUT_MS=300000            # Forwarding loop inactivity — closes half-open connections (default: 5min)
# PROXY_TUNNEL_TOTAL_TIMEOUT_MS=21600000  # Absolute ceiling on a tunnel's lifetime (default: 6h, slowloris defence)
# PROXY_DRAIN_GRACE_TIMEOUT_MS=30000      # Grace window for tunnels during graceful drain on shutdown (default: 30s)
# PROXY_NUM_ACCEPTORS=100                 # Ranch acceptor processes per listener (default: 100)

# =============================================================================
# Background Job Schedules
# =============================================================================
# ENQUEUE_EXECUTIONS_SCHEDULE=* * * * *      # Enqueue pending command executions (default: every 1min)
# REPORT_EXECUTIONS_SCHEDULE=* * * * *       # Report completed executions to admin (default: every 1min)
# SYNC_EXECUTIONS_SCHEDULE=*/2 * * * *       # Sync unprocessed executions via HTTP fallback (default: every 2min)
# REPORT_HEALTH_CHECK_SCHEDULE=*/2 * * * *   # Report node health via HTTP fallback (default: every 2min)
# DISCOVER_ADMINS_SCHEDULE=*/3 * * * *       # Probe VPN for admin peers (default: every 3min)
# CHECK_SELF_UPDATE_SCHEDULE=0 */2 * * *     # Poll admin for self-update requests via HTTP fallback (default: every 2h)
# PUSH_METRICS_SCHEDULE=*/2 * * * *          # Push metrics to admin via HTTP fallback (default: every 2min)
# PULL_VPN_CONFIG_SCHEDULE=0 0 * * *         # Pull full VPN config from Netmaker as DNS recovery backstop (default: daily)

# =============================================================================
# VPN
# =============================================================================
# VPN_READY_TIMEOUT_SECONDS=30   # How long to wait for VPN to be ready before aborting (default: 30)
# PULL_VPN_CONFIG_ENABLED=true   # Last-resort backstop for DNS recovery after netclient daemon
#                                # restarts. Disable only on severely resource-starved machines
#                                # where netclient pull causes disruptive WireGuard interface
#                                # resets — broken DNS can then persist indefinitely. (default: true)

# =============================================================================
# DERP Map Cache
# =============================================================================
# DERP_MAP_REFRESH_INTERVAL_MS=300000    # Stable refresh interval once the map has been fetched
#                                        # (default: 5 min). On startup the cache warms up fast:
#                                        # first attempt at 5 s, doubling each miss until this
#                                        # value is reached. Set lower (e.g. 60000) for faster
#                                        # rotation in test/dev environments.

# =============================================================================
# VPN / WireGuard
# =============================================================================
# Controls netclient's WireGuard backend (checked at entrypoint and by netclient).
# "wireguard-go" → userspace wireguard-go, DERP relay enabled (default in containers)
# unset          → kernel WireGuard module (better performance, no DERP; requires kernel module on host)
# WG_QUICK_USERSPACE_IMPLEMENTATION=wireguard-go

# =============================================================================
# Database & Data Paths (SQLite)
# =============================================================================
# DATA_DIR sets the root for all persistent agent state (default: /app/data).
# Subdirectories are implicit — no need to set them individually:
#   ${DATA_DIR}/agent/edge_agent.db  — SQLite database
#   ${DATA_DIR}/vpn/                 — netclient state (/etc/netclient symlinks here)
#   ${DATA_DIR}/ssh/                 — SSH host keys (persisted across container restarts)
#
# Mount a single volume to persist everything:
#   volumes:
#     - edge_agent_data:/app/data
#
# DATA_DIR=/app/data
# DB_POOL_SIZE=10
